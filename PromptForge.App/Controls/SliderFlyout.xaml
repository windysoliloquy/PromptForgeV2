<UserControl x:Class="PromptForge.App.Controls.SliderFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Name="Root"
             HorizontalAlignment="Stretch">
    <Grid>
        <ToggleButton x:Name="FlyoutButton"
                      Style="{DynamicResource SliderFlyoutButtonStyle}"
                      MinHeight="84"
                      HorizontalAlignment="Stretch"
                      HorizontalContentAlignment="Stretch">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Text="{Binding Label, ElementName=Root}"
                           Style="{DynamicResource BodyTextStyle}"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />

                <Border Grid.Row="1"
                        Style="{DynamicResource SemanticValuePillBorderStyle}"
                        Margin="0,8,0,0"
                        HorizontalAlignment="Left">
                    <TextBlock Text="{Binding ValueText, ElementName=Root}"
                               Style="{DynamicResource SemanticValuePillTextStyle}" />
                </Border>

                <Border Grid.Row="2" Height="0" Background="Transparent" />
            </Grid>
        </ToggleButton>

        <Popup x:Name="FlyoutPopup"
               PlacementTarget="{Binding ElementName=FlyoutButton}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade"
               IsOpen="{Binding IsChecked, ElementName=FlyoutButton, Mode=TwoWay}">
            <Border Style="{DynamicResource SliderFlyoutPopupBorderStyle}"
                    Width="300"
                    Margin="0,8,0,0">
                <StackPanel>
                    <TextBlock Text="{Binding Label, ElementName=Root}"
                               Style="{DynamicResource SectionTitleTextStyle}"
                               Margin="0,0,0,6"
                               TextWrapping="Wrap" />
                    <Border Style="{DynamicResource SemanticValuePillBorderStyle}"
                            Margin="0,0,0,10"
                            HorizontalAlignment="Left">
                        <TextBlock Text="{Binding ValueText, ElementName=Root}"
                                   Style="{DynamicResource SemanticValuePillTextStyle}" />
                    </Border>
                    <TextBlock Text="{Binding HelperText, ElementName=Root}"
                               Style="{DynamicResource BodyMutedTextStyle}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,12" />
                    <Slider Minimum="{Binding Minimum, ElementName=Root}"
                            Maximum="{Binding Maximum, ElementName=Root}"
                            Value="{Binding Value, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            TickFrequency="1"
                            IsSnapToTickEnabled="False"
                            Style="{DynamicResource AppSliderStyle}" />
                    <TextBlock Margin="0,8,0,0"
                               Text="{Binding GuideText, ElementName=Root}"
                               Style="{DynamicResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</UserControl>
