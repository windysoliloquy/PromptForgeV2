<UserControl x:Class="PromptForge.App.Controls.SliderFlyout"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             x:Name="Root"
             HorizontalAlignment="Stretch">
    <UserControl.Resources>
        <Duration x:Key="SliderButtonPressDuration">0:0:0.08</Duration>
        <Duration x:Key="SliderButtonCollapseDuration">0:0:0.09</Duration>
        <Duration x:Key="SliderButtonReturnDuration">0:0:1.0</Duration>
        <Duration x:Key="SliderButtonHoldUntilPopupReadyDuration">0:0:1.16</Duration>
        <Duration x:Key="SliderButtonReturnRevealDuration">0:0:0.05</Duration>
        <Duration x:Key="ButtonGlowRiseDuration">0:0:0.12</Duration>
        <Duration x:Key="ButtonGlowFadeDuration">0:0:0.24</Duration>
        <Duration x:Key="PopupEdgeTraceDuration">0:0:0.09</Duration>
        <Duration x:Key="PopupGlowHoldDuration">0:0:0.16</Duration>
        <Duration x:Key="PopupGlowFadeDuration">0:0:0.26</Duration>
        <sys:Double x:Key="SliderButtonPressScale">0.94</sys:Double>
        <sys:Double x:Key="SliderButtonCollapseScaleX">0.28</sys:Double>
        <sys:Double x:Key="SliderButtonCollapseScaleY">0.1</sys:Double>
        <sys:Double x:Key="SliderButtonCollapsedOpacity">0</sys:Double>
        <sys:Double x:Key="SliderButtonReturnStartOpacity">0.01</sys:Double>
        <sys:Double x:Key="SliderButtonReturnRevealThreshold">0.82</sys:Double>
        <sys:Double x:Key="SliderPopupGlowPeakOpacity">0.95</sys:Double>
        <sys:Double x:Key="SliderPopupGlowRestOpacity">0.28</sys:Double>
        <sys:Double x:Key="SliderButtonGlowPeakOpacity">0.88</sys:Double>
        <sys:Double x:Key="SliderEdgeTraceThickness">1.5</sys:Double>
    </UserControl.Resources>
    <Grid>
        <Grid x:Name="FlyoutPlacementAnchor">
            <ToggleButton x:Name="FlyoutButton"
                          RenderTransformOrigin="0.5,0.5"
                          Checked="FlyoutButton_OnChecked"
                          Unchecked="FlyoutButton_OnUnchecked">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton" BasedOn="{StaticResource SliderFlyoutButtonStyle}">
                        <Setter Property="MinHeight" Value="84" />
                        <Setter Property="HorizontalAlignment" Value="Stretch" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="RootBorder"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="14"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                          VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="RootBorder" Property="BorderBrush" Value="{DynamicResource InputBorderHoverBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding UseCompactChipTrigger, ElementName=Root}" Value="True">
                                <Setter Property="MinHeight" Value="32" />
                                <Setter Property="Padding" Value="9,4" />
                                <Setter Property="HorizontalContentAlignment" Value="Center" />
                                <Setter Property="VerticalContentAlignment" Value="Center" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>
                <ToggleButton.RenderTransform>
                    <ScaleTransform x:Name="FlyoutButtonScaleTransform"
                                    ScaleX="1"
                                    ScaleY="1" />
                </ToggleButton.RenderTransform>
                <Grid>
                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Visible" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UseCompactChipTrigger, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Text="{Binding Label, ElementName=Root}"
                                   FontWeight="SemiBold"
                                   TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource BodyTextStyle}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseCompactChipTrigger, ElementName=Root}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <Border Grid.Row="1"
                                Margin="0,8,0,0"
                                HorizontalAlignment="Left">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource SemanticValuePillBorderStyle}">
                                    <Setter Property="Margin" Value="0,8,0,0" />
                                    <Setter Property="HorizontalAlignment" Value="Left" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UseCompactChipTrigger, ElementName=Root}" Value="True">
                                            <Setter Property="Margin" Value="0" />
                                            <Setter Property="HorizontalAlignment" Value="Center" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="{Binding ButtonValueText, ElementName=Root}"
                                       Style="{DynamicResource SemanticValuePillTextStyle}" />
                        </Border>

                        <Border Grid.Row="2" Height="0" Background="Transparent" />
                    </Grid>

                    <Grid>
                        <Grid.Style>
                            <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding UseCompactChipTrigger, ElementName=Root}" Value="True">
                                        <Setter Property="Visibility" Value="Visible" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Grid.Style>
                        <Border Style="{DynamicResource SemanticValuePillBorderStyle}"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">
                            <TextBlock Text="{Binding ButtonValueText, ElementName=Root}"
                                       Style="{DynamicResource SemanticValuePillTextStyle}" />
                        </Border>
                    </Grid>
                </Grid>
            </ToggleButton>

            <Border x:Name="ButtonGlowOverlay"
                    IsHitTestVisible="False"
                    Opacity="0"
                    CornerRadius="14"
                    BorderThickness="1.5"
                    BorderBrush="{StaticResource SliderFlyoutGlowPeakBrush}">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0"
                                      Color="#FFDFA43A" />
                </Border.Effect>
            </Border>
        </Grid>

        <Popup x:Name="FlyoutPopup"
               PlacementTarget="{Binding ElementName=FlyoutPlacementAnchor}"
               Placement="Bottom"
               AllowsTransparency="True"
               StaysOpen="False"
               PopupAnimation="Fade"
               Opened="FlyoutPopup_OnOpened"
               Closed="FlyoutPopup_OnClosed"
               IsOpen="{Binding IsChecked, ElementName=FlyoutButton, Mode=TwoWay}">
            <Grid Width="300"
                  Margin="0,8,0,0">
                <Border x:Name="PopupBaseBorder"
                        Style="{DynamicResource SliderFlyoutPopupBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="{Binding Label, ElementName=Root}"
                                   Style="{DynamicResource SectionTitleTextStyle}"
                                   Margin="0,0,0,6"
                                   TextWrapping="Wrap" />
                        <Border Style="{DynamicResource SemanticValuePillBorderStyle}"
                                Margin="0,0,0,10"
                                HorizontalAlignment="Left">
                            <TextBlock Text="{Binding ValueText, ElementName=Root}"
                                       Style="{DynamicResource SemanticValuePillTextStyle}" />
                        </Border>
                        <TextBlock Text="{Binding HelperText, ElementName=Root}"
                                   Style="{DynamicResource BodyMutedTextStyle}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <Slider x:Name="ValueSlider"
                                Minimum="{Binding Minimum, ElementName=Root}"
                                Maximum="{Binding Maximum, ElementName=Root}"
                                Value="{Binding Value, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TickFrequency="1"
                                IsSnapToTickEnabled="False"
                                ValueChanged="ValueSlider_OnValueChanged"
                                Style="{DynamicResource AppSliderStyle}" />
                        <Border Margin="0,10,0,0"
                                Padding="0,10,0,0"
                                BorderThickness="0,1,0,0"
                                BorderBrush="{DynamicResource AppCardBorderBrush}"
                                Visibility="{Binding ShowExcludeFromPrompt, ElementName=Root, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <CheckBox x:Name="ExcludeFromPromptCheckBox"
                                          Content="Exclude from prompt"
                                          IsChecked="{Binding IsExcludedFromPrompt, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Checked="ExcludeFromPromptCheckBox_OnChecked"
                                          Unchecked="ExcludeFromPromptCheckBox_OnUnchecked"
                                          Style="{DynamicResource AppCheckBoxStyle}" />
                            <TextBlock Text="Keeps the slider value, but omits this slider's positive-prompt phrase."
                                       Style="{DynamicResource BodyMutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                        <TextBlock Margin="0,8,0,0"
                                   Text="{Binding GuideText, ElementName=Root}"
                                   Style="{DynamicResource BodyMutedTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <Grid x:Name="PopupGlowOverlay"
                      IsHitTestVisible="False"
                      ClipToBounds="True"
                      Opacity="0">
                    <Border x:Name="PopupGlowBorder"
                            CornerRadius="16"
                            BorderThickness="1.5"
                            BorderBrush="{StaticResource SliderFlyoutGlowPeakBrush}">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="20"
                                              ShadowDepth="0"
                                              Opacity="0"
                                              Color="#FFDFA43A" />
                        </Border.Effect>
                    </Border>

                    <Rectangle x:Name="TopEdgeTrace"
                               Height="{StaticResource SliderEdgeTraceThickness}"
                               RadiusX="1"
                               RadiusY="1"
                               Fill="{StaticResource SliderFlyoutGlowPeakBrush}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Width="0"
                               Margin="14,0,14,0" />
                    <Rectangle x:Name="RightEdgeTrace"
                               Width="{StaticResource SliderEdgeTraceThickness}"
                               RadiusX="1"
                               RadiusY="1"
                               Fill="{StaticResource SliderFlyoutGlowPeakBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Top"
                               Height="0"
                               Margin="0,14,0,14" />
                    <Rectangle x:Name="BottomEdgeTrace"
                               Height="{StaticResource SliderEdgeTraceThickness}"
                               RadiusX="1"
                               RadiusY="1"
                               Fill="{StaticResource SliderFlyoutGlowPeakBrush}"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Bottom"
                               Width="0"
                               Margin="14,0,14,0" />
                    <Rectangle x:Name="LeftEdgeTrace"
                               Width="{StaticResource SliderEdgeTraceThickness}"
                               RadiusX="1"
                               RadiusY="1"
                               Fill="{StaticResource SliderFlyoutGlowPeakBrush}"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Bottom"
                               Height="0"
                               Margin="0,14,0,14" />
                </Grid>
            </Grid>
        </Popup>
    </Grid>
</UserControl>
