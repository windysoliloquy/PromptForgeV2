<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    <Color x:Key="AppBackgroundColor">#FF171B23</Color>
    <Color x:Key="CardColor">#FF1F2530</Color>
    <Color x:Key="BorderColor">#FF334155</Color>
    <Color x:Key="InputBorderColor">#FF3A4558</Color>
    <Color x:Key="InputBorderHoverColor">#FF51637D</Color>
    <Color x:Key="InputBorderFocusColor">#FF6FB0FF</Color>
    <Color x:Key="AccentColor">#FF6FB0FF</Color>
    <Color x:Key="AccentColorHover">#FF5297EA</Color>
    <Color x:Key="AccentSoftColor">#FF263B5A</Color>
    <Color x:Key="TextPrimaryColor">#FFF2F5FB</Color>
    <Color x:Key="TextMutedColor">#FFB5C0D0</Color>
    <Color x:Key="InputBackgroundColor">#FF252C39</Color>
    <Color x:Key="SubtleSurfaceColor">#FF232A36</Color>
    <Color x:Key="PopupSurfaceColor">#FF202733</Color>
    <Color x:Key="PopupBorderColor">#FF42526A</Color>
    <Color x:Key="SemanticChipSurfaceColor">#FF273245</Color>
    <Color x:Key="SemanticChipBorderColor">#FF36465E</Color>
    <Color x:Key="ShadowColor">#FF000000</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBackgroundColor}" />
    <SolidColorBrush x:Key="CardBrush" Color="{StaticResource CardColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="InputBorderBrush" Color="{StaticResource InputBorderColor}" />
    <SolidColorBrush x:Key="InputBorderHoverBrush" Color="{StaticResource InputBorderHoverColor}" />
    <SolidColorBrush x:Key="InputBorderFocusBrush" Color="{StaticResource InputBorderFocusColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentColorHover}" />
    <SolidColorBrush x:Key="AccentSoftBrush" Color="{StaticResource AccentSoftColor}" />
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="InputBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="SubtleSurfaceBrush" Color="{StaticResource SubtleSurfaceColor}" />
    <SolidColorBrush x:Key="PopupSurfaceBrush" Color="{StaticResource PopupSurfaceColor}" />
    <SolidColorBrush x:Key="PopupBorderBrush" Color="{StaticResource PopupBorderColor}" />
    <SolidColorBrush x:Key="SemanticChipSurfaceBrush" Color="{StaticResource SemanticChipSurfaceColor}" />
    <SolidColorBrush x:Key="SemanticChipBorderBrush" Color="{StaticResource SemanticChipBorderColor}" />
    <SolidColorBrush x:Key="ComboBoxBackgroundBrush" Color="{StaticResource InputBackgroundColor}" />
    <SolidColorBrush x:Key="ComboBoxForegroundBrush" Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownBackgroundBrush" Color="{StaticResource PopupSurfaceColor}" />
    <SolidColorBrush x:Key="ComboBoxDropDownForegroundBrush" Color="{StaticResource TextPrimaryColor}" />
</ResourceDictionary>
