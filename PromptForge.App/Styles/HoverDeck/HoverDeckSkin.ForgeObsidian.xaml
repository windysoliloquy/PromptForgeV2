<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Color x:Key="HoverDeckOuterShellBackgroundColor">#FF050607</Color>
    <Color x:Key="HoverDeckInnerShellSurfaceColor">#FF0F1114</Color>
    <Color x:Key="HoverDeckTitleSurfaceColor">#FF15181C</Color>
    <Color x:Key="HoverDeckTitleBorderColor">#FF655437</Color>
    <Color x:Key="HoverDeckPrimaryBorderColor">#FF4F4029</Color>
    <Color x:Key="HoverDeckInnerDividerColor">#FF2C251B</Color>
    <Color x:Key="HoverDeckAccentLineColor">#FFD5B06A</Color>
    <Color x:Key="HoverDeckAccentGlowColor">#4CD8AF61</Color>
    <Color x:Key="HoverDeckTextPrimaryColor">#FFF6EFD9</Color>
    <Color x:Key="HoverDeckTextMutedColor">#FFB9A98A</Color>
    <Color x:Key="HoverDeckDangerHoverColor">#FF8E3C30</Color>
    <Color x:Key="HoverDeckCardSurfaceColor">#FF171A1F</Color>
    <Color x:Key="HoverDeckCardBorderColor">#FF6B5735</Color>
    <Color x:Key="HoverDeckControlSurfaceColor">#FF101317</Color>
    <Color x:Key="HoverDeckShadowColor">#FF000000</Color>
    <Color x:Key="HoverDeckAccentHighlightColor">#FFF2D39A</Color>
    <Color x:Key="HoverDeckHeaderCopperShadeColor">#FF221C14</Color>

    <SolidColorBrush x:Key="HoverDeckOuterShellBackgroundBrush" Color="{StaticResource HoverDeckOuterShellBackgroundColor}" />
    <SolidColorBrush x:Key="HoverDeckInnerShellSurfaceBrush" Color="{StaticResource HoverDeckInnerShellSurfaceColor}" />
    <SolidColorBrush x:Key="HoverDeckTitleSurfaceBrush" Color="{StaticResource HoverDeckTitleSurfaceColor}" />
    <SolidColorBrush x:Key="HoverDeckTitleBorderBrush" Color="{StaticResource HoverDeckTitleBorderColor}" />
    <SolidColorBrush x:Key="HoverDeckPrimaryBorderBrush" Color="{StaticResource HoverDeckPrimaryBorderColor}" />
    <SolidColorBrush x:Key="HoverDeckInnerDividerBrush" Color="{StaticResource HoverDeckInnerDividerColor}" />
    <SolidColorBrush x:Key="HoverDeckAccentLineBrush" Color="{StaticResource HoverDeckAccentLineColor}" />
    <SolidColorBrush x:Key="HoverDeckAccentGlowBrush" Color="{StaticResource HoverDeckAccentGlowColor}" />
    <SolidColorBrush x:Key="HoverDeckTextPrimaryBrush" Color="{StaticResource HoverDeckTextPrimaryColor}" />
    <SolidColorBrush x:Key="HoverDeckTextMutedBrush" Color="{StaticResource HoverDeckTextMutedColor}" />
    <SolidColorBrush x:Key="HoverDeckDangerHoverBrush" Color="{StaticResource HoverDeckDangerHoverColor}" />
    <SolidColorBrush x:Key="HoverDeckCardSurfaceBrush" Color="{StaticResource HoverDeckCardSurfaceColor}" />
    <SolidColorBrush x:Key="HoverDeckCardBorderBrush" Color="{StaticResource HoverDeckCardBorderColor}" />
    <SolidColorBrush x:Key="HoverDeckControlSurfaceBrush" Color="{StaticResource HoverDeckControlSurfaceColor}" />
    <SolidColorBrush x:Key="HoverDeckAccentHighlightBrush" Color="{StaticResource HoverDeckAccentHighlightColor}" />
    <SolidColorBrush x:Key="HoverDeckHeaderCopperShadeBrush" Color="{StaticResource HoverDeckHeaderCopperShadeColor}" />

    <LinearGradientBrush x:Key="HoverDeckOuterShellGradientBrush" StartPoint="0,0" EndPoint="0.9,1">
        <GradientStop Color="#FF070809" Offset="0" />
        <GradientStop Color="{StaticResource HoverDeckOuterShellBackgroundColor}" Offset="0.28" />
        <GradientStop Color="#FF0A0C0D" Offset="0.66" />
        <GradientStop Color="#FF020304" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HoverDeckInnerShellGradientBrush" StartPoint="0,0" EndPoint="0.95,1">
        <GradientStop Color="#FF15181C" Offset="0" />
        <GradientStop Color="{StaticResource HoverDeckInnerShellSurfaceColor}" Offset="0.48" />
        <GradientStop Color="#FF0D0F12" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HoverDeckTitleGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1B1E23" Offset="0" />
        <GradientStop Color="{StaticResource HoverDeckTitleSurfaceColor}" Offset="0.52" />
        <GradientStop Color="#FF121418" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HoverDeckCardGradientBrush" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF1A1D22" Offset="0" />
        <GradientStop Color="{StaticResource HoverDeckCardSurfaceColor}" Offset="0.6" />
        <GradientStop Color="#FF111419" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HoverDeckAccentTrackBrush" StartPoint="0,0" EndPoint="1,0">
        <GradientStop Color="#00D5B06A" Offset="0" />
        <GradientStop Color="#A6D5B06A" Offset="0.15" />
        <GradientStop Color="#FFF1D39B" Offset="0.5" />
        <GradientStop Color="#A6D5B06A" Offset="0.85" />
        <GradientStop Color="#00D5B06A" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="HoverDeckTitleTextBrush" StartPoint="0,0.5" EndPoint="1,0.5">
        <GradientStop Color="#FFF3D7A3" Offset="0" />
        <GradientStop Color="#FFFFF4D9" Offset="0.44" />
        <GradientStop Color="#FFDFBC77" Offset="1" />
    </LinearGradientBrush>

    <RadialGradientBrush x:Key="HoverDeckHeaderGlowBrush" Center="0.24,0.1" GradientOrigin="0.24,0.1" RadiusX="0.85" RadiusY="0.85">
        <GradientStop Color="#36D8AF61" Offset="0" />
        <GradientStop Color="#18C09653" Offset="0.48" />
        <GradientStop Color="#00C09653" Offset="1" />
    </RadialGradientBrush>

    <RadialGradientBrush x:Key="HoverDeckShellBloomBrush" Center="0.5,0.02" GradientOrigin="0.5,0.02" RadiusX="1.2" RadiusY="0.9">
        <GradientStop Color="#26E0BE7A" Offset="0" />
        <GradientStop Color="#10C9A35E" Offset="0.4" />
        <GradientStop Color="#00C9A35E" Offset="1" />
    </RadialGradientBrush>

    <Style x:Key="HoverDeckTitleEyebrowTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource HoverDeckTextMutedBrush}" />
        <Setter Property="FontSize" Value="10.5" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="HoverDeckTitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource HoverDeckTitleTextBrush}" />
        <Setter Property="FontSize" Value="17" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
        <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
    </Style>

    <Style x:Key="HoverDeckSubtitleTextStyle" TargetType="TextBlock">
        <Setter Property="Foreground" Value="{DynamicResource HoverDeckTextMutedBrush}" />
        <Setter Property="FontSize" Value="11.5" />
        <Setter Property="Opacity" Value="0.92" />
    </Style>

    <Style x:Key="HoverDeckCloseButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
        <Setter Property="Background" Value="{DynamicResource HoverDeckControlSurfaceBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource HoverDeckTextMutedBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource HoverDeckTitleBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="Width" Value="28" />
        <Setter Property="Height" Value="24" />
        <Setter Property="Margin" Value="0" />
        <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{DynamicResource HoverDeckDangerHoverBrush}" />
                <Setter Property="BorderBrush" Value="{DynamicResource HoverDeckAccentLineBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource HoverDeckTextPrimaryBrush}" />
            </Trigger>
            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter Property="BorderBrush" Value="{DynamicResource HoverDeckAccentLineBrush}" />
                <Setter Property="Foreground" Value="{DynamicResource HoverDeckTextPrimaryBrush}" />
            </Trigger>
        </Style.Triggers>
    </Style>
</ResourceDictionary>
