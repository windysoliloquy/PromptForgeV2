                                    <StackPanel Margin="14">
                                        <TextBlock Text="Prompt Preview" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Margin="0,4,0,12" Text="The prompt updates instantly as you adjust the controls." Style="{StaticResource BodyMutedTextStyle}" />
                                        <TextBox Text="{Binding PromptPreview, Mode=OneWay}"
                                                 IsReadOnly="True"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True"
                                                 VerticalScrollBarVisibility="Auto"
                                                 MinHeight="240"
                                                 Style="{StaticResource PromptPreviewTextBoxStyle}"
                                                 Visibility="{Binding ShowInteractivePromptPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                        <ScrollViewer x:Name="PositivePromptDemoPreviewScrollViewer"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled"
                                                      MinHeight="240"
                                                      Focusable="False"
                                                      ContextMenuService.IsEnabled="False"
                                                      Visibility="{Binding ShowDemoPromptPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                            <Border Style="{StaticResource PromptPreviewDisplayBorderStyle}"
                                                    Width="{Binding ViewportWidth, ElementName=PositivePromptDemoPreviewScrollViewer}"
                                                    Focusable="False"
                                                    ContextMenuService.IsEnabled="False">
                                                <TextBlock Text="{Binding PromptPreview}"
                                                           Style="{StaticResource PromptPreviewDisplayTextStyle}" />
                                            </Border>
                                        </ScrollViewer>
                                        <StackPanel Margin="0,10,0,0">
                                            <CheckBox Content="Semantic pair interactions"
                                                      IsChecked="{Binding SemanticPairInteractions, Mode=TwoWay}"
                                                      IsEnabled="{Binding CanUseCompressionControls}"
                                                      Margin="0,6,0,0"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <Border Style="{StaticResource WarmGoldInsetBorderStyle}" />
                                </Grid>
                            </Border>

                            <StackPanel Grid.Column="2">
                                <animeLaneReplacements:AnimeLanePanel />
                                <Border Padding="14"
                                        CornerRadius="18"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        Background="{DynamicResource SubtleSurfaceBrush}"
                                        VerticalAlignment="Stretch"
                                        Visibility="{Binding ShowComicBookModifierPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="0">
                                            <TextBlock Text="Comic Book Modifiers" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="Compact subtype and ink-forward accents. Speech bubbles only trigger when quoted dialogue is present."
                                                       Margin="0,4,0,10"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Grid.Row="1"
                                                    Grid.ColumnSpan="2">
                                            <TextBlock Text="Comic Book Style" Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox ItemsSource="{Binding ComicBookStyles}"
                                                      SelectedItem="{Binding ComicBookStyle}"
                                                      Style="{StaticResource AppComboBoxStyle}" />
                                            <TextBlock Text="Rendering Accents" Style="{StaticResource FieldLabelTextStyle}" Margin="0,10,0,0" />
                                            <UniformGrid Columns="2">
                                            <CheckBox Content="Bold Ink"
                                                      IsChecked="{Binding ComicBookBoldInk}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                            <CheckBox Content="Halftone Shading"
                                                      IsChecked="{Binding ComicBookHalftoneShading}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                            <CheckBox Content="Panel Framing"
                                                      IsChecked="{Binding ComicBookPanelFraming}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                            <CheckBox Content="Dynamic Poses"
                                                      IsChecked="{Binding ComicBookDynamicPoses}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                            <CheckBox Content="Speed Lines"
                                                      IsChecked="{Binding ComicBookSpeedLines}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                            <CheckBox Content="High Contrast Lighting"
                                                      IsChecked="{Binding ComicBookHighContrastLighting}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                            <CheckBox x:Name="ComicBookSpeechBubblesToggle"
                                                      Content="Speech Bubbles"
                                                      IsChecked="{Binding ComicBookSpeechBubbles}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                            </UniformGrid>
                                            <Popup Placement="Right"
                                                   PlacementTarget="{Binding ElementName=ComicBookSpeechBubblesToggle}"
                                                   HorizontalOffset="12"
                                                   VerticalOffset="-16"
                                                   AllowsTransparency="True"
                                                   PopupAnimation="Fade"
                                                   StaysOpen="False"
                                                   IsOpen="{Binding IsSpeechBubbleOptionsOpen, Mode=TwoWay}">
                                                <Border Width="320"
                                                        Padding="16"
                                                        Style="{StaticResource CardBorderStyle}"
                                                        SnapsToDevicePixels="True">
                                                    <StackPanel>
                                                        <TextBlock Text="Speech Bubble Options"
                                                                   Style="{StaticResource SectionTitleTextStyle}" />
                                                        <TextBlock Text="{Binding SpeechBubbleHelperText}"
                                                                   Margin="0,6,0,12"
                                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                                   TextWrapping="Wrap" />
                                                        <Border Padding="10"
                                                                Margin="0,0,0,12"
                                                                CornerRadius="10"
                                                                BorderThickness="1"
                                                                BorderBrush="{DynamicResource AccentBrush}"
                                                                Background="{DynamicResource SubtleSurfaceBrush}"
                                                                Visibility="{Binding ShowSpeechBubbleWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock Text="{Binding SpeechBubbleWarningText}"
                                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                                       TextWrapping="Wrap" />
                                                        </Border>

                                                        <TextBlock Text="Bubble Mode" Style="{StaticResource FieldLabelTextStyle}" />
                                                        <ComboBox ItemsSource="{Binding SpeechBubbleModes}"
                                                                  SelectedItem="{Binding SpeechBubbleMode}"
                                                                  Style="{StaticResource AppComboBoxStyle}" />

                                                        <StackPanel Margin="0,12,0,0"
                                                                    Visibility="{Binding ShowBlankSpeechBubbleOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                            <TextBlock Text="Bubble Size" Style="{StaticResource FieldLabelTextStyle}" />
                                                            <ComboBox ItemsSource="{Binding SpeechBubbleSizes}"
                                                                      SelectedItem="{Binding SpeechBubbleSize}"
                                                                      Style="{StaticResource AppComboBoxStyle}" />
                                                        <CheckBox Content="Stylized Bubble Shape"
                                                                      IsChecked="{Binding StylizedSpeechBubbleShape}"
                                                                      Margin="0,10,0,0"
                                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Popup>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                                <ContentControl Content="{Binding ActiveStandardLanePanel}"
                                                ContentTemplate="{StaticResource StandardLanePanelTemplate}"
                                                VerticalAlignment="Top"
                                                Visibility="{Binding ShowCompactTattooArtPanel, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <ContentControl Content="{Binding ActiveStandardLanePanel}"
                                                ContentTemplate="{StaticResource StandardLanePanelTemplate}"
                                                VerticalAlignment="Top"
                                                Visibility="{Binding ShowResolvedStandardLanePanel, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                <Border Padding="14"
                                        CornerRadius="18"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        Background="{DynamicResource SubtleSurfaceBrush}"
                                        VerticalAlignment="Stretch"
                                        Visibility="{Binding ShowVintageBendModifierPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="*" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Row="0"
                                                    Grid.Column="0">
                                            <TextBlock Text="Vintage Bend Modifiers" Style="{StaticResource FieldLabelTextStyle}" />
                                            <TextBlock Text="Compact semantic world-state modifiers for the Vintage Bend pack."
                                                       Margin="0,4,0,10"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>

                                        <UniformGrid Grid.Row="1"
                                                     Grid.ColumnSpan="2"
                                                     Columns="2">
                                            <CheckBox Content="Period Artifacts"
                                                      IsChecked="{Binding VintageBendPeriodArtifacts}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                            <CheckBox Content="Urban Civilian"
                                                      IsChecked="{Binding VintageBendUrbanCivilian}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                        </UniformGrid>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}"
                            Padding="20"
                            Margin="0,16,0,0"
                            Visibility="{Binding ShowArtistBlendSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Artist Blend Summary" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,4,0,10" Text="{Binding ArtistBlendSummaryTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding ArtistBlendSummaryBody}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                            <UniformGrid Margin="0,12,0,0" Columns="2">
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Composition" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding CompositionDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Palette" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding PaletteDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Surface" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding SurfaceDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Mood" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding MoodDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}"
                            Padding="20"
                            Margin="0,16,0,0"
                            Visibility="{Binding ShowNegativePrompt, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Negative Prompt" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBox Text="{Binding NegativePromptPreview, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="110"
                                     Style="{StaticResource PromptPreviewTextBoxStyle}"
                                     Visibility="{Binding ShowInteractivePromptPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ScrollViewer x:Name="NegativePromptDemoPreviewScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MinHeight="110"
                                          Focusable="False"
                                          ContextMenuService.IsEnabled="False"
                                          Visibility="{Binding ShowDemoPromptPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Style="{StaticResource PromptPreviewDisplayBorderStyle}"
                                        Width="{Binding ViewportWidth, ElementName=NegativePromptDemoPreviewScrollViewer}"
                                        Focusable="False"
                                        ContextMenuService.IsEnabled="False">
                                    <TextBlock Text="{Binding NegativePromptPreview}"
                                               Style="{StaticResource PromptPreviewDisplayTextStyle}" />
                                </Border>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
                </Grid>
            </ScrollViewer>

            <Border Style="{StaticResource CardBorderStyle}"
                    Padding="24"
                    Margin="0,16,0,0"
                    Visibility="{Binding ShowLockedLanePane, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="{Binding LockedLaneHeadline}"
                               Style="{StaticResource SectionTitleTextStyle}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardBorderStyle}"
                    Padding="24"
                    Margin="0,16,0,0"
                    Visibility="{Binding ShowDemoExpiredLockScreen, Converter={StaticResource BooleanToVisibilityConverter}}">
                <StackPanel>
                    <TextBlock Text="Demo Locked"
                               Style="{StaticResource SectionTitleTextStyle}" />
                    <TextBlock Margin="0,6,0,0"
                               Text="The Prompt Forge demo has reached its export limit on this machine."
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock Margin="0,10,0,0"
                               Text="Prompt output and authoring controls are now hidden until the full version is unlocked."
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                    <Border Style="{StaticResource InfoChipBorderStyle}"
                            Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="{Binding DemoModeHeadline}"
                                       Style="{StaticResource ChipValueTextStyle}" />
                            <TextBlock Text="{Binding DemoModeBody}"
                                       Margin="0,5,0,0"
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <TextBlock Margin="0,16,0,0"
                               Text="Use the Version button above to import an unlock file and restore the full workspace."
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </DockPanel>
        <Grid Panel.ZIndex="50"
              Grid.ColumnSpan="3"
              Background="#78081216"
              Visibility="{Binding IsArtistPhraseEditorMainHostOpen, ElementName=MainWindowRoot, Converter={StaticResource BooleanToVisibilityConverter}}" />
        <Popup x:Name="ArtistPhraseEditorPopup"
               Placement="Relative"
               PlacementTarget="{Binding ElementName=RootLayout}"
               AllowsTransparency="True"
               PopupAnimation="Fade"
               StaysOpen="True"
               IsOpen="{Binding IsArtistPhraseEditorMainHostOpen, ElementName=MainWindowRoot, Mode=OneWay}"
               Opened="OnArtistPhraseEditorPopupOpened"
               Closed="OnArtistPhraseEditorPopupClosed">
            <Border x:Name="ArtistPhraseEditorPopupCard"
                    Width="560"
                    MaxWidth="560"
                    Padding="20"
                    Style="{StaticResource CardBorderStyle}"
                    SnapsToDevicePixels="True">
                <StackPanel>
                    <Border x:Name="ArtistPhraseEditorDragHandle"
                            Background="{DynamicResource SubtleSurfaceBrush}"
                            BorderBrush="{DynamicResource SemanticChipBorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,10"
                            Margin="0,0,0,14"
                            Cursor="SizeAll"
                            MouseLeftButtonDown="OnArtistPhraseEditorDragHandleMouseLeftButtonDown"
                            MouseMove="OnArtistPhraseEditorDragHandleMouseMove"
                            MouseLeftButtonUp="OnArtistPhraseEditorDragHandleMouseLeftButtonUp">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="{Binding ArtistPhraseEditorTitle}" Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="Drag this header to move the editor. Save applies only to this artist slot."
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <TextBlock Grid.Column="1"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Text="Drag"
                                       Style="{StaticResource ChipLabelTextStyle}" />
                        </Grid>
                    </Border>

                    <TextBlock Text="Prefix" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBox Text="{Binding ArtistPhraseEditorPrefix, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="72" />

                    <TextBlock Text="Artist" Style="{StaticResource FieldLabelTextStyle}" />
                    <Border Style="{StaticResource InfoChipBorderStyle}" Padding="12" Margin="0,0,0,4">
                        <TextBlock Text="{Binding ArtistPhraseEditorArtistName}"
                                   Style="{StaticResource ChipValueTextStyle}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Text="Suffix" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBox Text="{Binding ArtistPhraseEditorSuffix, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource AppTextBoxStyle}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="72" />

                    <TextBlock Text="Preview" Style="{StaticResource FieldLabelTextStyle}" />
                    <Border Style="{StaticResource InfoChipBorderStyle}" Padding="12">
                        <TextBlock Text="{Binding ArtistPhraseEditorPreview}"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   TextWrapping="Wrap" />
                    </Border>

                    <TextBlock Margin="0,10,0,0"
                               Text="Generated reference"
                               Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBlock Text="{Binding ArtistPhraseEditorGeneratedPhrase}"
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />

                    <ItemsControl ItemsSource="{Binding ArtistPhraseQuickInsertGroups}" Margin="0,14,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,10">
                                    <TextBlock Text="{Binding Title}" Style="{StaticResource OnboardingAccentTextStyle}" />
                                    <ItemsControl ItemsSource="{Binding Inserts}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Content="{Binding Label}"
                                                        Command="{Binding DataContext.InsertArtistPhraseQuickInsertCommand, RelativeSource={RelativeSource AncestorType=Popup}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="0,0,8,8"
                                                        Padding="10,6"
                                                        ToolTip="{Binding Fragment}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <UniformGrid Columns="3" Margin="0,16,0,0">
                        <Button Content="Save"
                                Command="{Binding SaveArtistPhraseEditorCommand}"
                                Style="{StaticResource EmphasisSecondaryButtonStyle}" />
                        <Button Content="Reset to Generated"
                                Command="{Binding ResetArtistPhraseEditorCommand}"
                                Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Cancel"
                                Command="{Binding CancelArtistPhraseEditorCommand}"
                                Style="{StaticResource TertiaryButtonStyle}" />
                    </UniformGrid>
                </StackPanel>
            </Border>
        </Popup>
    </Grid>
</Window>






