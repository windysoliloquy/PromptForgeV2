<Window x:Class="PromptForge.App.MainWindow"
        x:Name="MainWindowRoot"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:controls="clr-namespace:PromptForge.App.Controls"
        xmlns:converters="clr-namespace:PromptForge.App.Converters"
        xmlns:animeLaneReplacements="clr-namespace:PromptForge.App.Views.LaneReplacements.Anime"
        xmlns:sharedLaneReplacements="clr-namespace:PromptForge.App.Views.LaneReplacements.Shared"
        xmlns:compactWorkstation="clr-namespace:PromptForge.App.Views.CompactWorkstation"
        Title="Prompt Forge"
        Icon="/Assets/PromptForge.ico"
        Height="940"
        Width="1480"
        MinHeight="820"
        MinWidth="1320"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBackgroundBrush}"
        PreviewMouseDown="OnWindowPreviewMouseDown">
    <Window.Resources>
        <converters:IntentModePickerTextConverter x:Key="IntentModePickerTextConverter" />
        <Style x:Key="HoverDeckLiveHeaderPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource AppHeaderBorderStyle}">
            <Setter Property="Background" Value="{DynamicResource HoverDeckInnerShellGradientBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HoverDeckCardBorderBrush}" />
        </Style>
        <Style x:Key="HoverDeckLiveSectionPanelStyle"
               TargetType="Border"
               BasedOn="{StaticResource SectionCardStyle}">
            <Setter Property="Background" Value="{DynamicResource HoverDeckInnerShellGradientBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource HoverDeckCardBorderBrush}" />
        </Style>
        <sys:Double x:Key="ForgeButtonPressScale">0.9</sys:Double>
        <sys:Double x:Key="ForgeButtonCollapseScaleX">0.72</sys:Double>
        <sys:Double x:Key="ForgeButtonCollapseScaleY">0.06</sys:Double>
        <sys:Double x:Key="ForgeButtonCollapsedOpacity">0.04</sys:Double>
        <sys:Double x:Key="ForgeReducedMotionButtonPressScale">0.94</sys:Double>
        <sys:Double x:Key="ForgeReducedMotionButtonCollapseScaleX">0.88</sys:Double>
        <sys:Double x:Key="ForgeReducedMotionButtonCollapseScaleY">0.52</sys:Double>
        <sys:Double x:Key="ForgeReducedMotionButtonCollapsedOpacity">0.18</sys:Double>
        <sys:Double x:Key="ForgeBorderRestOpacity">0.16</sys:Double>
        <sys:Double x:Key="ForgeBorderPeakOpacity">1</sys:Double>
        <sys:Double x:Key="ForgeReducedMotionBorderPeakOpacity">0.82</sys:Double>

        <Color x:Key="ForgeBorderRestColor">#33F3C66B</Color>
        <Color x:Key="ForgeBorderActiveColor">#FFDFA43A</Color>
        <Color x:Key="ForgeBorderPeakColor">#FFF6D98C</Color>
        <Color x:Key="ForgeSuccessPeakColor">#FFF6D17A</Color>
        <Color x:Key="ForgeSuccessRestColor">#00F6D17A</Color>

        <Duration x:Key="ForgeButtonPressDuration">0:0:0.09</Duration>
        <Duration x:Key="ForgeButtonCollapseDuration">0:0:0.08</Duration>
        <Duration x:Key="ForgeButtonReturnDuration">0:0:0.12</Duration>
        <Duration x:Key="ForgeReducedMotionButtonPressDuration">0:0:0.08</Duration>
        <Duration x:Key="ForgeReducedMotionButtonCollapseDuration">0:0:0.08</Duration>
        <Duration x:Key="ForgeReducedMotionButtonReturnDuration">0:0:0.1</Duration>
        <Duration x:Key="ForgeBorderBuildDuration">0:0:0.09</Duration>
        <Duration x:Key="ForgeBorderPeakDuration">0:0:0.12</Duration>
        <Duration x:Key="ForgeBorderFadeDuration">0:0:0.22</Duration>
        <Duration x:Key="ForgeBorderOpacityRiseDuration">0:0:0.08</Duration>
        <Duration x:Key="ForgeBorderOpacityFadeDuration">0:0:0.28</Duration>
        <Duration x:Key="ForgeReducedMotionBorderRiseDuration">0:0:0.05</Duration>
        <Duration x:Key="ForgeReducedMotionBorderFadeDuration">0:0:0.18</Duration>
        <Duration x:Key="ForgeSuccessFadeInDuration">0:0:0.08</Duration>
        <Duration x:Key="ForgeSuccessFadeOutDuration">0:0:0.2</Duration>
        <Duration x:Key="ForgeReducedMotionSuccessFadeInDuration">0:0:0.05</Duration>
        <Duration x:Key="ForgeReducedMotionSuccessFadeOutDuration">0:0:0.16</Duration>

        <sys:TimeSpan x:Key="ForgeButtonCollapseBegin">0:0:0.08</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeButtonReturnBegin">0:0:0.24</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeBorderIgnitionBegin">0:0:0.12</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeBorderPeakBegin">0:0:0.21</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeBorderFadeBegin">0:0:0.35</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeBorderOpacityFadeBegin">0:0:0.24</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeSuccessBegin">0:0:0.29</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeSuccessFadeBegin">0:0:0.95</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeReducedMotionBorderBegin">0:0:0.03</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeReducedMotionButtonCollapseBegin">0:0:0.06</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeReducedMotionButtonReturnBegin">0:0:0.16</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeReducedMotionBorderFadeBegin">0:0:0.18</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeReducedMotionSuccessBegin">0:0:0.22</sys:TimeSpan>
        <sys:TimeSpan x:Key="ForgeReducedMotionSuccessFadeBegin">0:0:0.8</sys:TimeSpan>
        <Storyboard x:Key="CopyPromptBorderStoryboard">
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="{StaticResource ForgeButtonPressScale}"
                             Duration="{StaticResource ForgeButtonPressDuration}"
                             />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="{StaticResource ForgeButtonPressScale}"
                             Duration="{StaticResource ForgeButtonPressDuration}"
                             />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="{StaticResource ForgeButtonCollapseScaleX}"
                             BeginTime="{StaticResource ForgeButtonCollapseBegin}"
                             Duration="{StaticResource ForgeButtonCollapseDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="{StaticResource ForgeButtonCollapseScaleY}"
                             BeginTime="{StaticResource ForgeButtonCollapseBegin}"
                             Duration="{StaticResource ForgeButtonCollapseDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButton"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeButtonCollapsedOpacity}"
                             BeginTime="{StaticResource ForgeButtonCollapseBegin}"
                             Duration="{StaticResource ForgeButtonCollapseDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="1"
                             BeginTime="{StaticResource ForgeButtonReturnBegin}"
                             Duration="{StaticResource ForgeButtonReturnDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="1"
                             BeginTime="{StaticResource ForgeButtonReturnBegin}"
                             Duration="{StaticResource ForgeButtonReturnDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButton"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             BeginTime="{StaticResource ForgeButtonReturnBegin}"
                             Duration="{StaticResource ForgeButtonReturnDuration}" />

            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderActiveColor}"
                            BeginTime="{StaticResource ForgeBorderIgnitionBegin}"
                            Duration="{StaticResource ForgeBorderBuildDuration}" />
            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderPeakColor}"
                            BeginTime="{StaticResource ForgeBorderPeakBegin}"
                            Duration="{StaticResource ForgeBorderPeakDuration}" />
            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderRestColor}"
                            BeginTime="{StaticResource ForgeBorderFadeBegin}"
                            Duration="{StaticResource ForgeBorderFadeDuration}" />

            <DoubleAnimation Storyboard.TargetName="ActionsCardBorderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeBorderPeakOpacity}"
                             BeginTime="{StaticResource ForgeBorderIgnitionBegin}"
                             Duration="{StaticResource ForgeBorderOpacityRiseDuration}" />
            <DoubleAnimation Storyboard.TargetName="ActionsCardBorderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeBorderRestOpacity}"
                             BeginTime="{StaticResource ForgeBorderOpacityFadeBegin}"
                             Duration="{StaticResource ForgeBorderOpacityFadeDuration}" />


            <DoubleAnimation Storyboard.TargetName="CopyPromptSuccessText"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             BeginTime="{StaticResource ForgeSuccessBegin}"
                             Duration="{StaticResource ForgeSuccessFadeInDuration}" />
            <ColorAnimation Storyboard.TargetName="ForgeSuccessBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeSuccessPeakColor}"
                            BeginTime="{StaticResource ForgeSuccessBegin}"
                            Duration="{StaticResource ForgeSuccessFadeInDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptSuccessText"
                             Storyboard.TargetProperty="Opacity"
                             To="0"
                             BeginTime="{StaticResource ForgeSuccessFadeBegin}"
                             Duration="{StaticResource ForgeSuccessFadeOutDuration}" />
            <ColorAnimation Storyboard.TargetName="ForgeSuccessBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeSuccessRestColor}"
                            BeginTime="{StaticResource ForgeSuccessFadeBegin}"
                            Duration="{StaticResource ForgeSuccessFadeOutDuration}" />
        </Storyboard>

        <Storyboard x:Key="ActionCardBorderGlowStoryboard">
            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderActiveColor}"
                            BeginTime="{StaticResource ForgeBorderIgnitionBegin}"
                            Duration="{StaticResource ForgeBorderBuildDuration}" />
            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderPeakColor}"
                            BeginTime="{StaticResource ForgeBorderPeakBegin}"
                            Duration="{StaticResource ForgeBorderPeakDuration}" />
            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderRestColor}"
                            BeginTime="{StaticResource ForgeBorderFadeBegin}"
                            Duration="{StaticResource ForgeBorderFadeDuration}" />

            <DoubleAnimation Storyboard.TargetName="ActionsCardBorderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeBorderPeakOpacity}"
                             BeginTime="{StaticResource ForgeBorderIgnitionBegin}"
                             Duration="{StaticResource ForgeBorderOpacityRiseDuration}" />
            <DoubleAnimation Storyboard.TargetName="ActionsCardBorderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeBorderRestOpacity}"
                             BeginTime="{StaticResource ForgeBorderOpacityFadeBegin}"
                             Duration="{StaticResource ForgeBorderOpacityFadeDuration}" />
        </Storyboard>

        <Storyboard x:Key="CopyPromptReducedMotionStoryboard">
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleX"
                             From="1"
                             To="{StaticResource ForgeReducedMotionButtonPressScale}"
                             Duration="{StaticResource ForgeReducedMotionButtonPressDuration}"
                             />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleY"
                             From="1"
                             To="{StaticResource ForgeReducedMotionButtonPressScale}"
                             Duration="{StaticResource ForgeReducedMotionButtonPressDuration}"
                             />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="{StaticResource ForgeReducedMotionButtonCollapseScaleX}"
                             BeginTime="{StaticResource ForgeReducedMotionButtonCollapseBegin}"
                             Duration="{StaticResource ForgeReducedMotionButtonCollapseDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="{StaticResource ForgeReducedMotionButtonCollapseScaleY}"
                             BeginTime="{StaticResource ForgeReducedMotionButtonCollapseBegin}"
                             Duration="{StaticResource ForgeReducedMotionButtonCollapseDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButton"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeReducedMotionButtonCollapsedOpacity}"
                             BeginTime="{StaticResource ForgeReducedMotionButtonCollapseBegin}"
                             Duration="{StaticResource ForgeReducedMotionButtonCollapseDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleX"
                             To="1"
                             BeginTime="{StaticResource ForgeReducedMotionButtonReturnBegin}"
                             Duration="{StaticResource ForgeReducedMotionButtonReturnDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButtonScale"
                             Storyboard.TargetProperty="ScaleY"
                             To="1"
                             BeginTime="{StaticResource ForgeReducedMotionButtonReturnBegin}"
                             Duration="{StaticResource ForgeReducedMotionButtonReturnDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptButton"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             BeginTime="{StaticResource ForgeReducedMotionButtonReturnBegin}"
                             Duration="{StaticResource ForgeReducedMotionButtonReturnDuration}" />

            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderPeakColor}"
                            BeginTime="{StaticResource ForgeReducedMotionBorderBegin}"
                            Duration="{StaticResource ForgeButtonPressDuration}" />
            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderRestColor}"
                            BeginTime="{StaticResource ForgeReducedMotionBorderFadeBegin}"
                            Duration="{StaticResource ForgeReducedMotionBorderFadeDuration}" />
            <DoubleAnimation Storyboard.TargetName="ActionsCardBorderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeReducedMotionBorderPeakOpacity}"
                             BeginTime="{StaticResource ForgeReducedMotionBorderBegin}"
                             Duration="{StaticResource ForgeReducedMotionBorderRiseDuration}" />
            <DoubleAnimation Storyboard.TargetName="ActionsCardBorderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeBorderRestOpacity}"
                             BeginTime="{StaticResource ForgeReducedMotionBorderFadeBegin}"
                             Duration="{StaticResource ForgeReducedMotionBorderFadeDuration}" />


            <DoubleAnimation Storyboard.TargetName="CopyPromptSuccessText"
                             Storyboard.TargetProperty="Opacity"
                             To="1"
                             BeginTime="{StaticResource ForgeReducedMotionSuccessBegin}"
                             Duration="{StaticResource ForgeReducedMotionSuccessFadeInDuration}" />
            <ColorAnimation Storyboard.TargetName="ForgeSuccessBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeSuccessPeakColor}"
                            BeginTime="{StaticResource ForgeReducedMotionSuccessBegin}"
                            Duration="{StaticResource ForgeReducedMotionSuccessFadeInDuration}" />
            <DoubleAnimation Storyboard.TargetName="CopyPromptSuccessText"
                             Storyboard.TargetProperty="Opacity"
                             To="0"
                             BeginTime="{StaticResource ForgeReducedMotionSuccessFadeBegin}"
                             Duration="{StaticResource ForgeReducedMotionSuccessFadeOutDuration}" />
            <ColorAnimation Storyboard.TargetName="ForgeSuccessBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeSuccessRestColor}"
                            BeginTime="{StaticResource ForgeReducedMotionSuccessFadeBegin}"
                            Duration="{StaticResource ForgeReducedMotionSuccessFadeOutDuration}" />
        </Storyboard>

        <Storyboard x:Key="ActionCardBorderGlowReducedMotionStoryboard">
            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderPeakColor}"
                            BeginTime="{StaticResource ForgeReducedMotionBorderBegin}"
                            Duration="{StaticResource ForgeButtonPressDuration}" />
            <ColorAnimation Storyboard.TargetName="ActionsCardBorderOverlayBrush"
                            Storyboard.TargetProperty="Color"
                            To="{StaticResource ForgeBorderRestColor}"
                            BeginTime="{StaticResource ForgeReducedMotionBorderFadeBegin}"
                            Duration="{StaticResource ForgeReducedMotionBorderFadeDuration}" />
            <DoubleAnimation Storyboard.TargetName="ActionsCardBorderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeReducedMotionBorderPeakOpacity}"
                             BeginTime="{StaticResource ForgeReducedMotionBorderBegin}"
                             Duration="{StaticResource ForgeReducedMotionBorderRiseDuration}" />
            <DoubleAnimation Storyboard.TargetName="ActionsCardBorderOverlay"
                             Storyboard.TargetProperty="Opacity"
                             To="{StaticResource ForgeBorderRestOpacity}"
                             BeginTime="{StaticResource ForgeReducedMotionBorderFadeBegin}"
                             Duration="{StaticResource ForgeReducedMotionBorderFadeDuration}" />
        </Storyboard>

        <DataTemplate x:Key="LaneHelpFooterTemplate">
            <Border>
                <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="New to Prompt Forge? Start here ---&gt;"
                               VerticalAlignment="Center"
                               Style="{StaticResource OnboardingAccentTextStyle}" />

                    <Grid Margin="8,0,0,0">
                        <ToggleButton x:Name="LaneHelpInfoToggle"
                                      Width="24"
                                      Height="24"
                                      Cursor="Hand"
                                      Background="{DynamicResource PopupSurfaceBrush}"
                                      BorderBrush="{DynamicResource PopupBorderBrush}"
                                      BorderThickness="1"
                                      Foreground="{DynamicResource TextPrimaryBrush}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="12">
                                        <TextBlock Text="i"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{TemplateBinding Foreground}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>

                        <Popup Placement="Top"
                               PlacementTarget="{Binding ElementName=LaneHelpInfoToggle}"
                               HorizontalOffset="-300"
                               VerticalOffset="-8"
                               AllowsTransparency="True"
                               PopupAnimation="Fade"
                               StaysOpen="False"
                               IsOpen="{Binding IsChecked, ElementName=LaneHelpInfoToggle, Mode=TwoWay}">
                            <Border Width="360"
                                    Padding="14"
                                    Style="{StaticResource CardBorderStyle}"
                                    Background="{DynamicResource PopupSurfaceBrush}"
                                    BorderBrush="{DynamicResource PopupBorderBrush}">
                                <StackPanel>
                                    <TextBlock Text="Getting Started with Prompt Forge"
                                               Style="{StaticResource SectionTitleTextStyle}" />
                                    <TextBlock Margin="0,8,0,0"
                                               Text="Prompt Forge has a lot of moving parts. Live group sessions are the main way tutorials, walkthroughs, and hands-on support are delivered, especially since lane behavior can vary across different image models and platforms."
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Margin="0,12,0,0"
                                               Text="Best for"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="&#8226; New users who want a proper walkthrough"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="&#8226; Users comparing results across different image models"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="&#8226; People who want help refining prompts and workflow"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Margin="0,12,0,0"
                                               Text="What sessions can help with"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="&#8226; Guided tutorials and app walkthroughs"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="&#8226; Lane-specific usage help"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="&#8226; Prompt troubleshooting and refinement"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="&#8226; Image feedback and critique"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="&#8226; Broader AI workflow questions when relevant"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Margin="0,12,0,0"
                                               Text="Access"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="A ChatGPT account is recommended, but users working with other image models are also welcome."
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Margin="0,12,0,0"
                                               Text="Getting set up"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <StackPanel Margin="0,4,0,0">
                                        <TextBlock Style="{StaticResource BodyMutedTextStyle}"
                                                   TextWrapping="Wrap">
                                            <Run Text="Email " />
                                            <InlineUIContainer BaselineAlignment="Center">
                                                <ToggleButton x:Name="LaneHelpEmailToggle"
                                                              Content="WindySoliloquy@gmail.com"
                                                              Padding="0"
                                                              Cursor="Hand"
                                                              Background="Transparent"
                                                              BorderThickness="0"
                                                              Foreground="{DynamicResource AccentBrush}">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <TextBlock Text="{TemplateBinding Content}"
                                                                       Foreground="{TemplateBinding Foreground}"
                                                                       TextDecorations="Underline"
                                                                       VerticalAlignment="Center" />
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>
                                            </InlineUIContainer>
                                            <Run Text=" to request access. Include your Prompt Forge version and the image model or platform you want help with. Setup is handled manually." />
                                        </TextBlock>

                                        <Popup Placement="Bottom"
                                               PlacementTarget="{Binding ElementName=LaneHelpEmailToggle}"
                                               HorizontalOffset="0"
                                               VerticalOffset="6"
                                               AllowsTransparency="True"
                                               PopupAnimation="Fade"
                                               StaysOpen="False"
                                               IsOpen="{Binding IsChecked, ElementName=LaneHelpEmailToggle, Mode=TwoWay}">
                                            <Border Padding="10"
                                                    Style="{StaticResource CardBorderStyle}"
                                                    Background="{DynamicResource PopupSurfaceBrush}"
                                                    BorderBrush="{DynamicResource PopupBorderBrush}">
                                                <Button Content="Copy email to clipboard"
                                                        Command="{Binding DataContext.CopyLaneHelpEmailCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="0" />
                                            </Border>
                                        </Popup>
                                    </StackPanel>

                                    <TextBlock Margin="0,12,0,0"
                                               Text="Group session pricing"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Monthly: $6.99"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="Quarterly: $17.99"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Text="Yearly: $49.99"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Margin="0,12,0,0"
                                               Text="Included unlock bonuses"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Some support purchases also include permanent lane unlock bonuses for the buyer's app. These unlocks do not expire, and buyers do not have to attend group sessions to receive them."
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />

                                    <TextBlock Margin="0,12,0,0"
                                               Text="Conduct"
                                               Style="{StaticResource FieldLabelTextStyle}" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="Group sessions are moderated to remain useful and respectful. Aggressive, disruptive, or abusive behavior can result in removal from group access without a refund."
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="StandardLanePanelTemplate">
            <Border Padding="14"
                    CornerRadius="18"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Background="{DynamicResource SubtleSurfaceBrush}"
                    VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Text="{Binding Description}"
                                   Margin="0,4,0,10"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Visibility="{Binding UseNormalizedSideBySideLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ItemsControl Grid.Column="0"
                                      ItemsSource="{Binding SubtypeSelectors}"
                                      Visibility="{Binding HasSubtypeSelectors, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding Options}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Key"
                                                  SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource AppComboBoxStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Grid.Column="2"
                                    Visibility="{Binding HasModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding AccentSectionTitle}"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Visibility="{Binding HasAccentSectionTitle, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Modifiers}"
                                          Margin="0,10,0,0"
                                          Visibility="{Binding HasModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="160"
                                              Margin="0,0,12,0">
                                            <CheckBox Content="{Binding Label}"
                                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Visibility="{Binding UseNormalizedSingleColumnLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding SubtypeSelectors}"
                                      Visibility="{Binding HasSubtypeSelectors, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding Options}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Key"
                                                  SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource AppComboBoxStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Visibility="{Binding ExcludeFromNormalizedSharedLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Mode Profile"
                                       Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock Text="Subdomain-specific suppression profiles. One mode stays active at all times for the current subdomain."
                                       Margin="0,4,0,10"
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       TextWrapping="Wrap" />

                            <StackPanel Visibility="{Binding DataContext.ShowInfographicModeGroup, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Infographic Modes" Style="{StaticResource FieldLabelTextStyle}" />
                                <CheckBox Content="Lean Explainer"
                                          IsChecked="{Binding DataContext.InfographicModeLeanExplainer, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Margin="0,10,0,0"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                                <CheckBox Content="Public Poster"
                                          IsChecked="{Binding DataContext.InfographicModePublicPoster, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                                <CheckBox Content="Reference Sheet"
                                          IsChecked="{Binding DataContext.InfographicModeReferenceSheet, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding DataContext.ShowDataVizModeGroup, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Data Viz Modes" Style="{StaticResource FieldLabelTextStyle}" />
                                <CheckBox Content="Chart Purity"
                                          IsChecked="{Binding DataContext.DataVizModeChartPurity, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Margin="0,10,0,0"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                                <CheckBox Content="Dashboard"
                                          IsChecked="{Binding DataContext.DataVizModeDashboard, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                                <CheckBox Content="Report Graphic"
                                          IsChecked="{Binding DataContext.DataVizModeReportGraphic, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{Binding AccentSectionTitle}"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Visibility="{Binding HasAccentSectionTitle, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <ItemsControl ItemsSource="{Binding Modifiers}"
                                      Margin="0,10,0,0"
                                      Visibility="{Binding HasModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="190"
                                          Margin="0,0,12,0">
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Style="{StaticResource AppCheckBoxStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>
        <Grid x:Name="RootLayout" Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="500" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Style="{StaticResource CardBorderStyle}"
                Padding="0"
                Visibility="{Binding ShowAuthoringWorkspace, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="16">
                    <Border Style="{StaticResource HoverDeckLiveHeaderPanelStyle}" Padding="16,18,16,16" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="2"
                                    Margin="0,2,0,2" />
                            <Grid Grid.Column="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <ContentControl Content="{Binding}"
                                                    ContentTemplate="{StaticResource LaneHelpFooterTemplate}" />
                                    <TextBlock Text="Windy Soliloquy's"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                    <TextBlock Text="Prompt Forge"
                                               Style="{StaticResource PageTitleTextStyle}"
                                               Cursor="Hand"
                                               MouseLeftButtonUp="OnBrandPromptForgeClick" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="A Visual Structured Prompt Synthesizer"
                                               Style="{StaticResource BodyMutedTextStyle}" />
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource ThemeSelectorBorderStyle}">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Skin" Style="{StaticResource ThemeSelectorLabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding Themes}"
                                      SelectedItem="{Binding SelectedThemeName}"
                                      Style="{StaticResource ThemeComboBoxStyle}" />
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource HoverDeckLiveSectionPanelStyle}">
                        <StackPanel>
                            <TextBlock Text="Intent" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Start by choosing the kind of image you want to create. Each domain includes its own lane, and many lanes include subdomains to help you narrow the direction."
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       TextWrapping="Wrap" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Intent Mode" Style="{StaticResource FieldLabelTextStyle}" />
                                <StackPanel Grid.Column="1"
                                            Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <CheckBox IsChecked="{Binding OverrideDefaultSliderPositions}"
                                              Margin="10,-5,0,0"
                                              Style="{StaticResource AppCheckBoxStyle}"
                                              ToolTipService.InitialShowDelay="150"
                                              ToolTipService.ShowDuration="17000">
                                        <CheckBox.Content>
                                            <TextBlock Text="Override default slider positions"
                                                       Margin="0"
                                                       VerticalAlignment="Center"
                                                       Style="{StaticResource FieldLabelTextStyle}" />
                                        </CheckBox.Content>
                                        <CheckBox.ToolTip>
                                            <ToolTip Placement="Bottom"
                                                     HorizontalOffset="8"
                                                     VerticalOffset="4"
                                                     MaxWidth="420">
                                                <Border Padding="10"
                                                        MaxWidth="420">
                                                    <TextBlock Text="Overriding default slider positions with current positions can degrade overall performance of the intended lane, but it can also create fun and unexpected effects. Some slider settings may clash with descriptors from other lanes, so use with caution."
                                                               TextWrapping="Wrap" />
                                                </Border>
                                            </ToolTip>
                                        </CheckBox.ToolTip>
                                    </CheckBox>
                                </StackPanel>
                            </Grid>
                            <ComboBox x:Name="IntentModeComboBox"
                                      ItemsSource="{Binding IntentModes}"
                                      SelectedIndex="{Binding IntentModeSelectedIndex, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      DropDownOpened="OnIntentModeDropDownOpened"
                                      DropDownClosed="OnIntentModeDropDownClosed"
                                      BorderBrush="{DynamicResource InputBorderFocusBrush}"
                                      Style="{StaticResource AppComboBoxStyle}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Converter={StaticResource IntentModePickerTextConverter}}"
                                                   VerticalAlignment="Center" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                            <Popup x:Name="PhotographyIntentPopup"
                                   Placement="Right"
                                   PlacementTarget="{Binding ElementName=IntentModeComboBox}"
                                   AllowsTransparency="True"
                                   PopupAnimation="Fade"
                                   StaysOpen="True"
                                   IsOpen="False">
                                <Border x:Name="PhotographyIntentPopupBorder"
                                        Width="{Binding ElementName=IntentModeComboBox, Path=ActualWidth}"
                                        Margin="8,0,0,0"
                                        Padding="6"
                                        Background="{DynamicResource PopupSurfaceBrush}"
                                        BorderBrush="{DynamicResource PopupBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="14">
                                    <StackPanel x:Name="PhotographyIntentPopupPanel" />
                                </Border>
                            </Popup>
                            <TextBlock Margin="0,7,0,0" Text="{Binding IntentModeSummary}" Style="{StaticResource BodyMutedTextStyle}" TextWrapping="Wrap" />
                            <StackPanel Margin="0,12,0,0"
                                        Visibility="{Binding ShowCustomRandomizeControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Randomize all sliders"
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           TextWrapping="Wrap" />
                                <CheckBox Content="Exclude Artist Sliders"
                                          IsChecked="{Binding ExcludeArtistSlidersFromRandomize}"
                                          Style="{StaticResource AppCheckBoxStyle}"
                                          Margin="0,8,0,0" />
                                <Button Content="Randomize"
                                        Command="{Binding RandomizeSlidersCommand}"
                                        Style="{StaticResource SecondaryButtonStyle}"
                                        Margin="0,8,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <StackPanel Visibility="{Binding ShowLockedLaneAuthoringSections, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Border Style="{StaticResource SectionCardStyle}"
                                Visibility="{Binding ShowExperimentalMacroControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="168" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                        <TextBlock Text="Experimental Controls" Style="{StaticResource SectionTitleTextStyle}" />
                                        <TextBlock Text="Macro / Guided steers the governed Experimental engine through perceptual bundles. Manual / Advanced exposes the underlying raw sliders without leaving Experimental."
                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Text="Mode" Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding ExperimentalControlModes}"
                                                  SelectedItem="{Binding ExperimentalControlMode}"
                                                  Style="{StaticResource AppComboBoxStyle}" />
                                    </StackPanel>
                                </Grid>

                                <StackPanel Margin="0,12,0,0"
                                            Visibility="{Binding IsExperimentalMacroGuidedMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <Border Style="{StaticResource CardBorderStyle}"
                                            Background="{DynamicResource SubtleSurfaceBrush}"
                                            BorderBrush="{DynamicResource SemanticChipBorderBrush}"
                                            Padding="12"
                                            Margin="0,0,0,10">
                                        <StackPanel>
                                            <controls:MacroPad Title="View Construction"
                                                               HelperText="Shape composition with framing width on the horizontal axis and vantage on the vertical axis."
                                                               HorizontalStartLabel="Intimate"
                                                               HorizontalEndLabel="Expansive"
                                                               VerticalLowLabel="Low vantage"
                                                               VerticalHighLabel="High vantage"
                                                               XValue="{Binding ViewConstructionHorizontal}"
                                                               YValue="{Binding ViewConstructionVertical}" />
                                            <TextBlock Text="Distance Bias" Style="{StaticResource FieldLabelTextStyle}" />
                                            <Slider Minimum="0"
                                                    Maximum="100"
                                                    Value="{Binding ViewConstructionDistanceBias}"
                                                    Style="{StaticResource AppSliderStyle}" />
                                            <DockPanel LastChildFill="False">
                                                <TextBlock Text="Close" Style="{StaticResource ChipLabelTextStyle}" />
                                                <TextBlock Text="Distant" Style="{StaticResource ChipLabelTextStyle}" DockPanel.Dock="Right" />
                                            </DockPanel>
                                            <TextBlock Text="{Binding ViewConstructionMacroSummary}"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource CardBorderStyle}"
                                            Background="{DynamicResource SubtleSurfaceBrush}"
                                            BorderBrush="{DynamicResource SemanticChipBorderBrush}"
                                            Padding="12"
                                            Margin="0,0,0,10">
                                        <StackPanel>
                                            <TextBlock Text="Light Atmosphere" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,6" />
                                            <TextBlock Text="Choose the lighting regime, then shape it with temperature on the horizontal axis and intensity on the vertical axis."
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,10" />
                                            <TextBlock Text="Lighting Preset" Style="{StaticResource FieldLabelTextStyle}" />
                                            <ComboBox ItemsSource="{Binding Lightings}"
                                                      SelectedItem="{Binding Lighting}"
                                                      Style="{StaticResource AppComboBoxStyle}" />
                                            <controls:MacroPad Title="Atmosphere Pad"
                                                               HelperText="Cool to warm shapes color temperature. Soft to radiant shapes intensity with moderate color/contrast lift."
                                                               HorizontalStartLabel="Cool"
                                                               HorizontalEndLabel="Warm"
                                                               VerticalLowLabel="Soft"
                                                               VerticalHighLabel="Radiant"
                                                               XValue="{Binding LightAtmosphereHorizontal}"
                                                               YValue="{Binding LightAtmosphereVertical}" />
                                            <TextBlock Text="{Binding LightAtmosphereMacroSummary}"
                                                       Style="{StaticResource BodyMutedTextStyle}"
                                                       Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Border>

                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="{DynamicResource SubtleSurfaceBrush}"
                                        BorderBrush="{DynamicResource SemanticChipBorderBrush}"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <controls:MacroPad Title="Material / Finish"
                                                           HelperText="Raw to polished steers finish. Sparse to dense steers detail build-up while texture depth follows behind."
                                                           HorizontalStartLabel="Raw"
                                                           HorizontalEndLabel="Polished"
                                                           VerticalLowLabel="Sparse"
                                                           VerticalHighLabel="Dense"
                                                           XValue="{Binding MaterialFinishHorizontal}"
                                                           YValue="{Binding MaterialFinishVertical}" />
                                        <TextBlock Text="{Binding MaterialFinishMacroSummary}"
                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="{DynamicResource SubtleSurfaceBrush}"
                                        BorderBrush="{DynamicResource SemanticChipBorderBrush}"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <TextBlock Text="Scene Richness" Style="{StaticResource FieldLabelTextStyle}" Margin="0,0,0,6" />
                                        <TextBlock Text="Build from minimal staging toward a more layered world. Environment and depth rise first, narrative follows more carefully."
                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,10" />
                                        <Slider Minimum="0"
                                                Maximum="100"
                                                Value="{Binding SceneRichness}"
                                                Style="{StaticResource AppSliderStyle}" />
                                        <DockPanel LastChildFill="False">
                                            <TextBlock Text="Minimal" Style="{StaticResource ChipLabelTextStyle}" />
                                            <TextBlock Text="World-rich" Style="{StaticResource ChipLabelTextStyle}" DockPanel.Dock="Right" />
                                        </DockPanel>
                                        <TextBlock Text="{Binding SceneRichnessMacroSummary}"
                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="{DynamicResource SubtleSurfaceBrush}"
                                        BorderBrush="{DynamicResource SemanticChipBorderBrush}"
                                        Padding="12"
                                        Margin="0,0,0,10">
                                    <StackPanel>
                                        <controls:MacroPad Title="Energy / Instability"
                                                           HelperText="Calm to kinetic drives motion. Controlled to unstable drives chaos, while tension rises from the combination."
                                                           HorizontalStartLabel="Calm"
                                                           HorizontalEndLabel="Kinetic"
                                                           VerticalLowLabel="Controlled"
                                                           VerticalHighLabel="Unstable"
                                                           XValue="{Binding EnergyInstabilityHorizontal}"
                                                           YValue="{Binding EnergyInstabilityVertical}" />
                                        <TextBlock Text="{Binding EnergyInstabilityMacroSummary}"
                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource CardBorderStyle}"
                                        Background="{DynamicResource SubtleSurfaceBrush}"
                                        BorderBrush="{DynamicResource SemanticChipBorderBrush}"
                                        Padding="12">
                                    <StackPanel>
                                        <controls:MacroPad Title="Tone"
                                                           HelperText="Serious to playful steers levity. Grounded to mythic lifts wonder and symbolism without overriding physical scene control."
                                                           HorizontalStartLabel="Serious"
                                                           HorizontalEndLabel="Playful"
                                                           VerticalLowLabel="Grounded"
                                                           VerticalHighLabel="Mythic"
                                                           XValue="{Binding ToneHorizontal}"
                                                           YValue="{Binding ToneVertical}" />
                                        <TextBlock Text="{Binding ToneMacroSummary}"
                                                   Style="{StaticResource BodyMutedTextStyle}"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Border Style="{StaticResource InfoChipBorderStyle}"
                                    Margin="0,12,0,0"
                                    Visibility="{Binding IsExperimentalManualAdvancedMode, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Manual / Advanced is active. The grouped raw Experimental sliders below now reflect the current macro-shaped values and remain fully editable."
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           TextWrapping="Wrap" />
                            </Border>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource HoverDeckLiveSectionPanelStyle}">
                        <StackPanel>
                            <Grid Margin="0,0,0,4">
                                <TextBlock Text="Subject"
                                           Style="{StaticResource SectionTitleTextStyle}"
                                           VerticalAlignment="Center" />
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0"
                                            Orientation="Horizontal"
                                            Margin="0,0,0,0">
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="0"
                                            Margin="0,0,8,0"
                                            Cursor="Hand"
                                            Focusable="True"
                                            HorizontalContentAlignment="Center"
                                            VerticalContentAlignment="Center"
                                            ToolTipService.InitialShowDelay="10">
                                        <Button.ToolTip>
                                            <ToolTip Placement="Bottom"
                                                     HorizontalOffset="8"
                                                     VerticalOffset="4"
                                                     MaxWidth="420">
                                                <Border Padding="10"
                                                        MaxWidth="420">
                                                    <TextBlock Text="Quickly replace your subject without retyping.&#x0a;&#x0a;Place your cursor at the end of the subject, then press Ctrl + Shift + Up Arrow to select the full line.&#x0a;Type a new subject, or press Ctrl + V to paste one from your clipboard.&#x0a;&#x0a;Tip: you can generate simple subject ideas in an LLM and paste them here to iterate quickly."
                                                               TextWrapping="Wrap"
                                                               Style="{StaticResource BodyMutedTextStyle}"
                                                               Foreground="Black" />
                                                </Border>
                                            </ToolTip>
                                        </Button.ToolTip>
                                        <Border Width="24"
                                                Height="24"
                                                CornerRadius="12"
                                                BorderThickness="1"
                                                BorderBrush="{DynamicResource TextPrimaryBrush}"
                                                Background="{DynamicResource AppBackgroundBrush}">
                                            <TextBlock Text="i"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource TextPrimaryBrush}" />
                                        </Border>
                                    </Button>
                                </StackPanel>

                                <Grid Grid.Column="1"
                                      Margin="8,0,0,0"
                                      HorizontalAlignment="Right"
                                      Visibility="{Binding HasLaneHelpTooltip, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <ToggleButton x:Name="SubjectLaneHelpInfoToggle"
                                                  Width="24"
                                                  Height="24"
                                                  Cursor="Hand"
                                                  Background="{DynamicResource PopupSurfaceBrush}"
                                                  BorderBrush="{DynamicResource PopupBorderBrush}"
                                                  BorderThickness="1"
                                                  Foreground="{DynamicResource TextPrimaryBrush}">
                                        <ToggleButton.Template>
                                            <ControlTemplate TargetType="ToggleButton">
                                                <Border Background="{TemplateBinding Background}"
                                                        BorderBrush="{TemplateBinding BorderBrush}"
                                                        BorderThickness="{TemplateBinding BorderThickness}"
                                                        CornerRadius="12">
                                                    <TextBlock Text="i"
                                                               FontSize="13"
                                                               FontWeight="SemiBold"
                                                               Foreground="{TemplateBinding Foreground}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    </Trigger>
                                                    <Trigger Property="IsChecked" Value="True">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </ToggleButton.Template>
                                    </ToggleButton>

                                    <Popup Placement="Bottom"
                                           PlacementTarget="{Binding ElementName=SubjectLaneHelpInfoToggle}"
                                           HorizontalOffset="0"
                                           VerticalOffset="6"
                                           AllowsTransparency="True"
                                           PopupAnimation="Fade"
                                           StaysOpen="False"
                                           IsOpen="{Binding IsChecked, ElementName=SubjectLaneHelpInfoToggle, Mode=TwoWay}">
                                        <Border Width="320"
                                                Padding="14"
                                                Style="{StaticResource CardBorderStyle}"
                                                Background="{DynamicResource PopupSurfaceBrush}"
                                                BorderBrush="{DynamicResource PopupBorderBrush}">
                                            <StackPanel>
                                                <TextBlock Text="Principle"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text="{Binding LaneHelpPrinciple}"
                                                           Margin="0,4,0,10"
                                                           Style="{StaticResource BodyMutedTextStyle}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="Weak"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text="{Binding LaneHelpWeak}"
                                                           Margin="0,4,0,10"
                                                           Style="{StaticResource BodyMutedTextStyle}"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="Stronger"
                                                           Style="{StaticResource FieldLabelTextStyle}" />
                                                <TextBlock Text="{Binding LaneHelpStronger}"
                                                           Margin="0,4,0,0"
                                                           Style="{StaticResource BodyMutedTextStyle}"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Grid>
                            <TextBox Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Style="{StaticResource AppTextBoxStyle}" />
                            <TextBlock Text="Action"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Visibility="{Binding ShowSubjectContextFields, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBox Text="{Binding Action, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"
                                     Visibility="{Binding ShowSubjectContextFields, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBlock Text="Relationship / Interaction"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Visibility="{Binding ShowSubjectContextFields, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <TextBox Text="{Binding Relationship, UpdateSourceTrigger=PropertyChanged}"
                                     Style="{StaticResource AppTextBoxStyle}"
                                     Visibility="{Binding ShowSubjectContextFields, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Visibility="{Binding ShowStandardManualStyleControlsCard, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Manual Style Controls" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Vintage Bend uses these same controls, but the prompt language resolves through the dedicated documentary pack."
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Visibility="{Binding IsVintageBendIntent, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       Margin="0,0,0,6" />
