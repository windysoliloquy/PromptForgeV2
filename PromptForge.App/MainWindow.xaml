<Window x:Class="PromptForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:PromptForge.App.Controls"
        Title="Prompt Forge"
        Icon="Assets/PromptForge.ico"
        Height="940"
        Width="1480"
        MinHeight="820"
        MinWidth="1320"
        Background="{DynamicResource AppBackgroundBrush}">
    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460" />
            <ColumnDefinition Width="16" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="16">
                    <Border Style="{StaticResource AppHeaderBorderStyle}" Padding="16,18,16,16" Margin="0,0,0,4">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="4" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Background="{DynamicResource AccentBrush}"
                                    CornerRadius="2"
                                    Margin="0,2,0,2" />
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Windy Soliloquy's"
                                           Style="{StaticResource BodyMutedTextStyle}" />
                                <TextBlock Text="Prompt Forge" Style="{StaticResource PageTitleTextStyle}" />
                                <TextBlock Margin="0,4,0,0"
                                           Text="A visual prompt synthesizer for structured prompt building."
                                           Style="{StaticResource BodyMutedTextStyle}" />
                            </StackPanel>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource ThemeSelectorBorderStyle}">
                        <DockPanel LastChildFill="False">
                            <TextBlock Text="Skin" Style="{StaticResource ThemeSelectorLabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding Themes}"
                                      SelectedItem="{Binding SelectedThemeName}"
                                      Style="{StaticResource ThemeComboBoxStyle}" />
                        </DockPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Intent" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Start with a bundled direction, or switch to Custom to reveal the full manual slider structure. Artist influence always stays available as a separate layer."
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="Intent Mode" Style="{StaticResource FieldLabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding IntentModes}" SelectedItem="{Binding IntentMode}" Style="{StaticResource AppComboBoxStyle}" />
                            <TextBlock Margin="0,7,0,0" Text="{Binding IntentModeSummary}" Style="{StaticResource BodyMutedTextStyle}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Subject" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Subject" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBox Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" />
                            <TextBlock Text="Action" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBox Text="{Binding Action, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" />
                            <TextBlock Text="Relationship / Interaction" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBox Text="{Binding Relationship, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Visibility="{Binding ShowManualIntentControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Manual Style Controls" Style="{StaticResource SectionTitleTextStyle}" />
                            <UniformGrid Columns="2" Margin="0,2,0,0">
                                <controls:SliderFlyout Label="Stylization" Value="{Binding Stylization}" ValueText="{Binding StylizationValueText}" GuideText="{Binding StylizationGuideText}" HelperText="{Binding StylizationHelper}" />
                                <controls:SliderFlyout Label="Realism" Value="{Binding Realism}" ValueText="{Binding RealismValueText}" GuideText="{Binding RealismGuideText}" HelperText="{Binding RealismHelper}" />
                                <controls:SliderFlyout Label="Texture Depth" Value="{Binding TextureDepth}" ValueText="{Binding TextureDepthValueText}" GuideText="{Binding TextureDepthGuideText}" HelperText="{Binding TextureDepthHelper}" />
                                <controls:SliderFlyout Label="Narrative Density" Value="{Binding NarrativeDensity}" ValueText="{Binding NarrativeDensityValueText}" GuideText="{Binding NarrativeDensityGuideText}" HelperText="{Binding NarrativeDensityHelper}" />
                                <controls:SliderFlyout Label="Symbolism" Value="{Binding Symbolism}" ValueText="{Binding SymbolismValueText}" GuideText="{Binding SymbolismGuideText}" HelperText="{Binding SymbolismHelper}" />
                                <controls:SliderFlyout Label="Surface Age" Value="{Binding SurfaceAge}" ValueText="{Binding SurfaceAgeValueText}" GuideText="{Binding SurfaceAgeGuideText}" HelperText="{Binding SurfaceAgeHelper}" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}">
                        <StackPanel>
                            <TextBlock Text="Artist Influence" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Artist influence stays active whether you use a bundled intent or the full custom structure."
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       TextWrapping="Wrap" />
                            <Grid Margin="0,2,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Material" Style="{StaticResource FieldLabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding Materials}" SelectedItem="{Binding Material}" Style="{StaticResource AppComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Art Style" Style="{StaticResource FieldLabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding ArtStyles}" SelectedItem="{Binding ArtStyle}" Style="{StaticResource AppComboBoxStyle}" />
                                </StackPanel>
                            </Grid>
                            <TextBlock Text="Primary Artist Influence" Style="{StaticResource FieldLabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding ArtistInfluences}" SelectedItem="{Binding ArtistInfluencePrimary}" IsEditable="True" IsTextSearchEnabled="True" Style="{StaticResource AppComboBoxStyle}" />
                            <controls:SliderFlyout Label="Primary Strength" Value="{Binding InfluenceStrengthPrimary}" ValueText="{Binding InfluenceStrengthPrimaryValueText}" GuideText="{Binding InfluenceStrengthPrimaryGuideText}" HelperText="Adjusts how strongly the primary artist shapes the prompt." ButtonWidth="404" />

                            <TextBlock Text="Secondary Artist Influence" Style="{StaticResource FieldLabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding ArtistInfluences}" SelectedItem="{Binding ArtistInfluenceSecondary}" IsEditable="True" IsTextSearchEnabled="True" Style="{StaticResource AppComboBoxStyle}" />
                            <controls:SliderFlyout Label="Secondary Strength" Value="{Binding InfluenceStrengthSecondary}" ValueText="{Binding InfluenceStrengthSecondaryValueText}" GuideText="{Binding InfluenceStrengthSecondaryGuideText}" HelperText="Adjusts how strongly the secondary artist accents the prompt." ButtonWidth="404" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Visibility="{Binding ShowManualIntentControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Manual Composition" Style="{StaticResource SectionTitleTextStyle}" />
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="12" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Camera Distance" Style="{StaticResource FieldLabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding CameraDistances}" SelectedItem="{Binding CameraDistance}" Style="{StaticResource AppComboBoxStyle}" />
                                </StackPanel>
                                <StackPanel Grid.Column="2">
                                    <TextBlock Text="Camera Angle" Style="{StaticResource FieldLabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding CameraAngles}" SelectedItem="{Binding CameraAngle}" Style="{StaticResource AppComboBoxStyle}" />
                                </StackPanel>
                            </Grid>
                            <UniformGrid Columns="2" Margin="0,3,0,0">
                                <controls:SliderFlyout Label="Background Complexity" Value="{Binding BackgroundComplexity}" ValueText="{Binding BackgroundComplexityValueText}" GuideText="{Binding BackgroundComplexityGuideText}" HelperText="{Binding BackgroundComplexityHelper}" />
                                <controls:SliderFlyout Label="Motion Energy" Value="{Binding MotionEnergy}" ValueText="{Binding MotionEnergyValueText}" GuideText="{Binding MotionEnergyGuideText}" HelperText="{Binding MotionEnergyHelper}" />
                                <controls:SliderFlyout Label="Atmospheric Depth" Value="{Binding AtmosphericDepth}" ValueText="{Binding AtmosphericDepthValueText}" GuideText="{Binding AtmosphericDepthGuideText}" HelperText="{Binding AtmosphericDepthHelper}" />
                                <controls:SliderFlyout Label="Chaos" Value="{Binding Chaos}" ValueText="{Binding ChaosValueText}" GuideText="{Binding ChaosGuideText}" HelperText="{Binding ChaosHelper}" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Visibility="{Binding ShowManualIntentControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Manual Mood" Style="{StaticResource SectionTitleTextStyle}" />
                            <UniformGrid Columns="2" Margin="0,2,0,0">
                                <controls:SliderFlyout Label="Whimsy" Value="{Binding Whimsy}" ValueText="{Binding WhimsyValueText}" GuideText="{Binding WhimsyGuideText}" HelperText="{Binding WhimsyHelper}" />
                                <controls:SliderFlyout Label="Tension" Value="{Binding Tension}" ValueText="{Binding TensionValueText}" GuideText="{Binding TensionGuideText}" HelperText="{Binding TensionHelper}" />
                                <controls:SliderFlyout Label="Awe" Value="{Binding Awe}" ValueText="{Binding AweValueText}" GuideText="{Binding AweGuideText}" HelperText="{Binding AweHelper}" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Visibility="{Binding ShowManualIntentControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Manual Lighting and Color" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Lighting" Style="{StaticResource FieldLabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding Lightings}" SelectedItem="{Binding Lighting}" Style="{StaticResource AppComboBoxStyle}" />
                            <UniformGrid Columns="2" Margin="0,3,0,0">
                                <controls:SliderFlyout Label="Saturation" Value="{Binding Saturation}" ValueText="{Binding SaturationValueText}" GuideText="{Binding SaturationGuideText}" HelperText="{Binding SaturationHelper}" />
                                <controls:SliderFlyout Label="Contrast" Value="{Binding Contrast}" ValueText="{Binding ContrastValueText}" GuideText="{Binding ContrastGuideText}" HelperText="{Binding ContrastHelper}" />
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Visibility="{Binding ShowManualIntentControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Manual Output" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Aspect Ratio" Style="{StaticResource FieldLabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding AspectRatios}" SelectedItem="{Binding AspectRatio}" Style="{StaticResource AppComboBoxStyle}" />
                            <CheckBox Content="Print-ready" IsChecked="{Binding PrintReady}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Transparent background" IsChecked="{Binding TransparentBackground}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Include negative prompt" IsChecked="{Binding UseNegativePrompt}" Style="{StaticResource AppCheckBoxStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource SectionCardStyle}" Visibility="{Binding ShowManualIntentControls, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Manual Negative Constraints" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Text="Common exclusions start enabled by default. Certain artists can relax individual constraints automatically when distortion is part of the intended look."
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       TextWrapping="Wrap" />
                            <CheckBox Content="Avoid clutter" IsChecked="{Binding AvoidClutter}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Avoid muddy lighting" IsChecked="{Binding AvoidMuddyLighting}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Avoid distorted anatomy" IsChecked="{Binding AvoidDistortedAnatomy}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Avoid extra limbs / fingers" IsChecked="{Binding AvoidExtraLimbs}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Avoid text or watermark artifacts" IsChecked="{Binding AvoidTextArtifacts}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Avoid oversaturation" IsChecked="{Binding AvoidOversaturation}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Avoid flat composition" IsChecked="{Binding AvoidFlatComposition}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Avoid messy background" IsChecked="{Binding AvoidMessyBackground}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Avoid weak material definition" IsChecked="{Binding AvoidWeakMaterialDefinition}" Style="{StaticResource AppCheckBoxStyle}" />
                            <CheckBox Content="Avoid blurry detail" IsChecked="{Binding AvoidBlurryDetail}" Style="{StaticResource AppCheckBoxStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Column="2" LastChildFill="True">
            <Border DockPanel.Dock="Bottom" Style="{StaticResource CardBorderStyle}" Padding="16,13" Margin="0,16,0,0">
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource BodyMutedTextStyle}" />
            </Border>

            <Border DockPanel.Dock="Bottom" Style="{StaticResource CardBorderStyle}" Padding="20" Margin="0,16,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="12" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Actions and Presets" Style="{StaticResource SectionTitleTextStyle}" />
                            <Border Style="{StaticResource InfoChipBorderStyle}"
                                    Margin="0,0,0,0"
                                    Visibility="{Binding ShowDemoModeBanner, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <StackPanel>
                                    <TextBlock Text="{Binding DemoModeHeadline}" Style="{StaticResource ChipValueTextStyle}" Margin="0" />
                                    <TextBlock Text="{Binding DemoModeBody}" Style="{StaticResource BodyMutedTextStyle}" TextWrapping="Wrap" Margin="0,5,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                        <Button Grid.Column="1"
                                Content="{Binding VersionButtonText}"
                                Click="OnVersionInfoClick"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Margin="12,0,0,0"
                                VerticalAlignment="Top" />
                    </Grid>
                    <UniformGrid Grid.Row="2" Columns="3">
                        <Button Content="Copy Prompt" Command="{Binding CopyPromptCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Content="Copy Negative Prompt" Command="{Binding CopyNegativePromptCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Reset" Command="{Binding ResetCommand}" Style="{StaticResource TertiaryButtonStyle}" />
                    </UniformGrid>
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="1.6*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Preset Name" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBox Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" />
                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                <Button Content="Save Preset" Command="{Binding SavePresetCommand}" Style="{StaticResource EmphasisSecondaryButtonStyle}" />
                                <Button Content="Rename Preset" Command="{Binding RenamePresetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </UniformGrid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Saved Presets" Style="{StaticResource FieldLabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding PresetNames}" SelectedItem="{Binding SelectedPresetName}" Style="{StaticResource AppComboBoxStyle}" />
                            <UniformGrid Columns="2" Margin="0,8,0,0">
                                <Button Content="Load Preset" Command="{Binding LoadPresetCommand}" Style="{StaticResource EmphasisSecondaryButtonStyle}" />
                                <Button Content="Delete Preset" Command="{Binding DeletePresetCommand}" Style="{StaticResource TertiaryButtonStyle}" />
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardBorderStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="Prompt Preview" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,4,0,12" Text="The prompt updates instantly as you adjust the controls." Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Text="{Binding PromptPreview, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="260"
                                     Style="{StaticResource PromptPreviewTextBoxStyle}"
                                     Visibility="{Binding ShowInteractivePromptPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ScrollViewer x:Name="PositivePromptDemoPreviewScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MinHeight="260"
                                          Focusable="False"
                                          ContextMenuService.IsEnabled="False"
                                          Visibility="{Binding ShowDemoPromptPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Style="{StaticResource PromptPreviewDisplayBorderStyle}"
                                        Width="{Binding ViewportWidth, ElementName=PositivePromptDemoPreviewScrollViewer}"
                                        Focusable="False"
                                        ContextMenuService.IsEnabled="False">
                                    <TextBlock Text="{Binding PromptPreview}"
                                               Style="{StaticResource PromptPreviewDisplayTextStyle}" />
                                </Border>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="20" Margin="0,16,0,0" Visibility="{Binding ShowArtistBlendSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Artist Blend Summary" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,4,0,10" Text="{Binding ArtistBlendSummaryTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding ArtistBlendSummaryBody}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                            <UniformGrid Margin="0,12,0,0" Columns="2">
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Composition" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding CompositionDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Palette" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding PaletteDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Surface" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding SurfaceDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Mood" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding MoodDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="20" Margin="0,16,0,0" Visibility="{Binding ShowNegativePrompt, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Negative Prompt" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBox Text="{Binding NegativePromptPreview, Mode=OneWay}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     VerticalScrollBarVisibility="Auto"
                                     MinHeight="110"
                                     Style="{StaticResource PromptPreviewTextBoxStyle}"
                                     Visibility="{Binding ShowInteractivePromptPreview, Converter={StaticResource BooleanToVisibilityConverter}}" />
                            <ScrollViewer x:Name="NegativePromptDemoPreviewScrollViewer"
                                          VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MinHeight="110"
                                          Focusable="False"
                                          ContextMenuService.IsEnabled="False"
                                          Visibility="{Binding ShowDemoPromptPreview, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <Border Style="{StaticResource PromptPreviewDisplayBorderStyle}"
                                        Width="{Binding ViewportWidth, ElementName=NegativePromptDemoPreviewScrollViewer}"
                                        Focusable="False"
                                        ContextMenuService.IsEnabled="False">
                                    <TextBlock Text="{Binding NegativePromptPreview}"
                                               Style="{StaticResource PromptPreviewDisplayTextStyle}" />
                                </Border>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>




