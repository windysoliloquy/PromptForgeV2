<Window x:Class="PromptForge.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompt Forge"
        Height="940"
        Width="1480"
        MinHeight="820"
        MinWidth="1320"
        Background="{StaticResource AppBackgroundBrush}">
    <Grid Margin="18">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="460" />
            <ColumnDefinition Width="18" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Style="{StaticResource CardBorderStyle}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Margin="18">
                    <TextBlock Text="Prompt Forge" Style="{StaticResource PageTitleTextStyle}" />
                    <TextBlock Margin="0,6,0,16" Text="A visual prompt synthesizer for structured prompt building." Style="{StaticResource BodyMutedTextStyle}" />

                    <Border Style="{StaticResource SectionCardStyle}"><StackPanel><TextBlock Text="Subject" Style="{StaticResource SectionTitleTextStyle}" /><TextBlock Text="Subject" Style="{StaticResource FieldLabelTextStyle}" /><TextBox Text="{Binding Subject, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" /><TextBlock Text="Action" Style="{StaticResource FieldLabelTextStyle}" /><TextBox Text="{Binding Action, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" /><TextBlock Text="Relationship / Interaction" Style="{StaticResource FieldLabelTextStyle}" /><TextBox Text="{Binding Relationship, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" /></StackPanel></Border>

                    <Border Style="{StaticResource SectionCardStyle}"><StackPanel>
                        <TextBlock Text="Style" Style="{StaticResource SectionTitleTextStyle}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Stylization" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Stylization}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding Stylization}" Style="{StaticResource AppSliderStyle}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Realism" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Realism}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding Realism}" Style="{StaticResource AppSliderStyle}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Texture Depth" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding TextureDepth}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding TextureDepth}" Style="{StaticResource AppSliderStyle}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Narrative Density" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding NarrativeDensity}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding NarrativeDensity}" Style="{StaticResource AppSliderStyle}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Symbolism" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Symbolism}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding Symbolism}" Style="{StaticResource AppSliderStyle}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Surface Age" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding SurfaceAge}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding SurfaceAge}" Style="{StaticResource AppSliderStyle}" />
                        <TextBlock Text="Material" Style="{StaticResource FieldLabelTextStyle}" /><ComboBox ItemsSource="{Binding Materials}" SelectedItem="{Binding Material}" Style="{StaticResource AppComboBoxStyle}" />
                        <TextBlock Text="Art Style" Style="{StaticResource FieldLabelTextStyle}" /><ComboBox ItemsSource="{Binding ArtStyles}" SelectedItem="{Binding ArtStyle}" Style="{StaticResource AppComboBoxStyle}" />
                        <TextBlock Text="Primary Artist Influence" Style="{StaticResource FieldLabelTextStyle}" /><ComboBox ItemsSource="{Binding ArtistInfluences}" SelectedItem="{Binding ArtistInfluencePrimary}" IsEditable="True" IsTextSearchEnabled="True" Style="{StaticResource AppComboBoxStyle}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Primary Influence Strength" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding InfluenceStrengthPrimary}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding InfluenceStrengthPrimary}" Style="{StaticResource AppSliderStyle}" />
                        <TextBlock Text="Secondary Artist Influence" Style="{StaticResource FieldLabelTextStyle}" /><ComboBox ItemsSource="{Binding ArtistInfluences}" SelectedItem="{Binding ArtistInfluenceSecondary}" IsEditable="True" IsTextSearchEnabled="True" Style="{StaticResource AppComboBoxStyle}" />
                        <Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Secondary Influence Strength" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding InfluenceStrengthSecondary}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding InfluenceStrengthSecondary}" Style="{StaticResource AppSliderStyle}" />
                    </StackPanel></Border>

                    <Border Style="{StaticResource SectionCardStyle}"><StackPanel><TextBlock Text="Composition" Style="{StaticResource SectionTitleTextStyle}" /><TextBlock Text="Camera Distance" Style="{StaticResource FieldLabelTextStyle}" /><ComboBox ItemsSource="{Binding CameraDistances}" SelectedItem="{Binding CameraDistance}" Style="{StaticResource AppComboBoxStyle}" /><TextBlock Text="Camera Angle" Style="{StaticResource FieldLabelTextStyle}" /><ComboBox ItemsSource="{Binding CameraAngles}" SelectedItem="{Binding CameraAngle}" Style="{StaticResource AppComboBoxStyle}" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Background Complexity" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding BackgroundComplexity}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding BackgroundComplexity}" Style="{StaticResource AppSliderStyle}" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Motion Energy" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding MotionEnergy}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding MotionEnergy}" Style="{StaticResource AppSliderStyle}" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Atmospheric Depth" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding AtmosphericDepth}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding AtmosphericDepth}" Style="{StaticResource AppSliderStyle}" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Chaos" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Chaos}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding Chaos}" Style="{StaticResource AppSliderStyle}" /></StackPanel></Border>

                    <Border Style="{StaticResource SectionCardStyle}"><StackPanel><TextBlock Text="Mood" Style="{StaticResource SectionTitleTextStyle}" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Whimsy" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Whimsy}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding Whimsy}" Style="{StaticResource AppSliderStyle}" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Tension" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Tension}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding Tension}" Style="{StaticResource AppSliderStyle}" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Awe" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Awe}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding Awe}" Style="{StaticResource AppSliderStyle}" /></StackPanel></Border>

                    <Border Style="{StaticResource SectionCardStyle}"><StackPanel><TextBlock Text="Lighting and Color" Style="{StaticResource SectionTitleTextStyle}" /><TextBlock Text="Lighting" Style="{StaticResource FieldLabelTextStyle}" /><ComboBox ItemsSource="{Binding Lightings}" SelectedItem="{Binding Lighting}" Style="{StaticResource AppComboBoxStyle}" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Saturation" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Saturation}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding Saturation}" Style="{StaticResource AppSliderStyle}" /><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions><TextBlock Text="Contrast" Style="{StaticResource FieldLabelTextStyle}" /><TextBlock Grid.Column="1" Text="{Binding Contrast}" Style="{StaticResource ValueTextStyle}" /></Grid><Slider Minimum="0" Maximum="100" Value="{Binding Contrast}" Style="{StaticResource AppSliderStyle}" /></StackPanel></Border>

                    <Border Style="{StaticResource SectionCardStyle}"><StackPanel><TextBlock Text="Output" Style="{StaticResource SectionTitleTextStyle}" /><TextBlock Text="Aspect Ratio" Style="{StaticResource FieldLabelTextStyle}" /><ComboBox ItemsSource="{Binding AspectRatios}" SelectedItem="{Binding AspectRatio}" Style="{StaticResource AppComboBoxStyle}" /><CheckBox Content="Print-ready" IsChecked="{Binding PrintReady}" Style="{StaticResource AppCheckBoxStyle}" /><CheckBox Content="Transparent background" IsChecked="{Binding TransparentBackground}" Style="{StaticResource AppCheckBoxStyle}" /><CheckBox Content="Use negative prompt" IsChecked="{Binding UseNegativePrompt}" Style="{StaticResource AppCheckBoxStyle}" /></StackPanel></Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <DockPanel Grid.Column="2" LastChildFill="True">
            <Border DockPanel.Dock="Bottom" Style="{StaticResource CardBorderStyle}" Padding="18,14" Margin="0,18,0,0">
                <TextBlock Text="{Binding StatusMessage}" Style="{StaticResource BodyMutedTextStyle}" />
            </Border>

            <Border DockPanel.Dock="Bottom" Style="{StaticResource CardBorderStyle}" Padding="22" Margin="0,18,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="14" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="16" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="Actions and Presets" Style="{StaticResource SectionTitleTextStyle}" />
                    <UniformGrid Grid.Row="2" Columns="3">
                        <Button Content="Copy Prompt" Command="{Binding CopyPromptCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                        <Button Content="Copy Negative Prompt" Command="{Binding CopyNegativePromptCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        <Button Content="Reset" Command="{Binding ResetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                    </UniformGrid>
                    <Grid Grid.Row="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2.2*" />
                            <ColumnDefinition Width="18" />
                            <ColumnDefinition Width="1.6*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Preset Name" Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBox Text="{Binding PresetName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource AppTextBoxStyle}" />
                            <UniformGrid Columns="2" Margin="0,10,0,0">
                                <Button Content="Save Preset" Command="{Binding SavePresetCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Content="Rename Preset" Command="{Binding RenamePresetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </UniformGrid>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Saved Presets" Style="{StaticResource FieldLabelTextStyle}" />
                            <ComboBox ItemsSource="{Binding PresetNames}" SelectedItem="{Binding SelectedPresetName}" Style="{StaticResource AppComboBoxStyle}" />
                            <UniformGrid Columns="2" Margin="0,10,0,0">
                                <Button Content="Load Preset" Command="{Binding LoadPresetCommand}" Style="{StaticResource PrimaryButtonStyle}" />
                                <Button Content="Delete Preset" Command="{Binding DeletePresetCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                            </UniformGrid>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>

            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Style="{StaticResource CardBorderStyle}" Padding="22">
                        <StackPanel>
                            <TextBlock Text="Prompt Preview" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,4,0,14" Text="The prompt updates instantly as you adjust the controls." Style="{StaticResource BodyMutedTextStyle}" />
                            <TextBox Text="{Binding PromptPreview, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" MinHeight="260" Style="{StaticResource PromptPreviewTextBoxStyle}" />
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="22" Margin="0,18,0,0" Visibility="{Binding ShowArtistBlendSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Artist Blend Summary" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBlock Margin="0,4,0,12" Text="{Binding ArtistBlendSummaryTitle}" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding ArtistBlendSummaryBody}" TextWrapping="Wrap" Style="{StaticResource BodyMutedTextStyle}" />
                            <UniformGrid Margin="0,14,0,0" Columns="2">
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Composition" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding CompositionDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Palette" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding PaletteDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Surface" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding SurfaceDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                                <Border Style="{StaticResource InfoChipBorderStyle}"><StackPanel><TextBlock Text="Mood" Style="{StaticResource ChipLabelTextStyle}" /><TextBlock Text="{Binding MoodDriver}" Style="{StaticResource ChipValueTextStyle}" TextWrapping="Wrap" /></StackPanel></Border>
                            </UniformGrid>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource CardBorderStyle}" Padding="22" Margin="0,18,0,0" Visibility="{Binding ShowNegativePrompt, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <StackPanel>
                            <TextBlock Text="Negative Prompt" Style="{StaticResource SectionTitleTextStyle}" />
                            <TextBox Text="{Binding NegativePromptPreview, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" MinHeight="110" Style="{StaticResource PromptPreviewTextBoxStyle}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Window>
