<UserControl x:Class="PromptForge.App.Views.CompactWorkstation.LiveLaneCardProjection"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:animeLaneReplacements="clr-namespace:PromptForge.App.Views.LaneReplacements.Anime"
             Focusable="False">
    <UserControl.Resources>
        <SolidColorBrush x:Key="HoverDeckProjectionShellBackgroundBrush" Color="#D0111316" />
        <SolidColorBrush x:Key="HoverDeckProjectionShellBorderBrush" Color="#6C7F6331" />
        <DataTemplate x:Key="StandardLanePanelTemplate">
            <Border Padding="14"
                    CornerRadius="18"
                    BorderThickness="1"
                    BorderBrush="{StaticResource HoverDeckProjectionShellBorderBrush}"
                    Background="{StaticResource HoverDeckProjectionShellBackgroundBrush}"
                    VerticalAlignment="Top">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0">
                        <TextBlock Text="{Binding Title}" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Text="{Binding Description}"
                                   Margin="0,4,0,10"
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>

                    <Grid Grid.Row="1"
                          Visibility="{Binding UseNormalizedSideBySideLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <ItemsControl Grid.Column="0"
                                      ItemsSource="{Binding SubtypeSelectors}"
                                      Visibility="{Binding HasSubtypeSelectors, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding Options}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Key"
                                                  SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource AppComboBoxStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Grid.Column="2"
                                    Visibility="{Binding HasModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="{Binding AccentSectionTitle}"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Visibility="{Binding HasAccentSectionTitle, Converter={StaticResource BooleanToVisibilityConverter}}" />

                            <ItemsControl ItemsSource="{Binding Modifiers}"
                                          Margin="0,10,0,0"
                                          Visibility="{Binding HasModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Width="160"
                                              Margin="0,0,12,0">
                                            <CheckBox Content="{Binding Label}"
                                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                      Style="{StaticResource AppCheckBoxStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1"
                                Visibility="{Binding UseNormalizedSingleColumnLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <ItemsControl ItemsSource="{Binding SubtypeSelectors}"
                                      Visibility="{Binding HasSubtypeSelectors, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Margin="0,0,0,10">
                                        <TextBlock Text="{Binding Label}" Style="{StaticResource FieldLabelTextStyle}" />
                                        <ComboBox ItemsSource="{Binding Options}"
                                                  DisplayMemberPath="Label"
                                                  SelectedValuePath="Key"
                                                  SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Style="{StaticResource AppComboBoxStyle}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Visibility="{Binding ExcludeFromNormalizedSharedLayout, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <TextBlock Text="Mode Profile"
                                       Style="{StaticResource FieldLabelTextStyle}" />
                            <TextBlock Text="Subdomain-specific suppression profiles. One mode stays active at all times for the current subdomain."
                                       Margin="0,4,0,10"
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       TextWrapping="Wrap" />

                            <StackPanel Visibility="{Binding DataContext.ShowInfographicModeGroup, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Infographic Modes" Style="{StaticResource FieldLabelTextStyle}" />
                                <CheckBox Content="Lean Explainer"
                                          IsChecked="{Binding DataContext.InfographicModeLeanExplainer, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Margin="0,10,0,0"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                                <CheckBox Content="Public Poster"
                                          IsChecked="{Binding DataContext.InfographicModePublicPoster, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                                <CheckBox Content="Reference Sheet"
                                          IsChecked="{Binding DataContext.InfographicModeReferenceSheet, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                            </StackPanel>

                            <StackPanel Visibility="{Binding DataContext.ShowDataVizModeGroup, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BooleanToVisibilityConverter}}">
                                <TextBlock Text="Data Viz Modes" Style="{StaticResource FieldLabelTextStyle}" />
                                <CheckBox Content="Chart Purity"
                                          IsChecked="{Binding DataContext.DataVizModeChartPurity, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Margin="0,10,0,0"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                                <CheckBox Content="Dashboard"
                                          IsChecked="{Binding DataContext.DataVizModeDashboard, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                                <CheckBox Content="Report Graphic"
                                          IsChecked="{Binding DataContext.DataVizModeReportGraphic, RelativeSource={RelativeSource AncestorType=Window}}"
                                          Style="{StaticResource AppCheckBoxStyle}" />
                            </StackPanel>
                        </StackPanel>

                        <TextBlock Text="{Binding AccentSectionTitle}"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Visibility="{Binding HasAccentSectionTitle, Converter={StaticResource BooleanToVisibilityConverter}}" />

                        <ItemsControl ItemsSource="{Binding Modifiers}"
                                      Margin="0,10,0,0"
                                      Visibility="{Binding HasModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="190"
                                          Margin="0,0,12,0">
                                        <CheckBox Content="{Binding Label}"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  Style="{StaticResource AppCheckBoxStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>

    <StackPanel>
        <animeLaneReplacements:AnimeLanePanel />
        <Border Padding="14"
                CornerRadius="18"
                BorderThickness="1"
                BorderBrush="{StaticResource HoverDeckProjectionShellBorderBrush}"
                Background="{StaticResource HoverDeckProjectionShellBackgroundBrush}"
                VerticalAlignment="Stretch"
                Visibility="{Binding ShowComicBookModifierPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0">
                    <TextBlock Text="Comic Book Modifiers" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBlock Text="Compact subtype and ink-forward accents. Speech bubbles only trigger when quoted dialogue is present."
                               Margin="0,4,0,10"
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Row="1"
                            Grid.ColumnSpan="2">
                    <TextBlock Text="Comic Book Style" Style="{StaticResource FieldLabelTextStyle}" />
                    <ComboBox ItemsSource="{Binding ComicBookStyles}"
                              SelectedItem="{Binding ComicBookStyle}"
                              Style="{StaticResource AppComboBoxStyle}" />
                    <TextBlock Text="Rendering Accents" Style="{StaticResource FieldLabelTextStyle}" Margin="0,10,0,0" />
                    <UniformGrid Columns="2">
                        <CheckBox Content="Bold Ink"
                                  IsChecked="{Binding ComicBookBoldInk}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Content="Halftone Shading"
                                  IsChecked="{Binding ComicBookHalftoneShading}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Content="Panel Framing"
                                  IsChecked="{Binding ComicBookPanelFraming}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Content="Dynamic Poses"
                                  IsChecked="{Binding ComicBookDynamicPoses}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Content="Speed Lines"
                                  IsChecked="{Binding ComicBookSpeedLines}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Content="High Contrast Lighting"
                                  IsChecked="{Binding ComicBookHighContrastLighting}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox x:Name="ComicBookSpeechBubblesToggle"
                                  Content="Speech Bubbles"
                                  IsChecked="{Binding ComicBookSpeechBubbles}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                    </UniformGrid>
                    <Popup Placement="Right"
                           PlacementTarget="{Binding ElementName=ComicBookSpeechBubblesToggle}"
                           HorizontalOffset="12"
                           VerticalOffset="-16"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False"
                           IsOpen="{Binding IsSpeechBubbleOptionsOpen, Mode=TwoWay}">
                        <Border Width="320"
                                Padding="16"
                                Style="{StaticResource CardBorderStyle}"
                                SnapsToDevicePixels="True">
                            <StackPanel>
                                <TextBlock Text="Speech Bubble Options"
                                           Style="{StaticResource SectionTitleTextStyle}" />
                                <TextBlock Text="{Binding SpeechBubbleHelperText}"
                                           Margin="0,6,0,12"
                                           Style="{StaticResource BodyMutedTextStyle}"
                                           TextWrapping="Wrap" />
                                <Border Padding="10"
                                        Margin="0,0,0,12"
                                        CornerRadius="10"
                                        BorderThickness="1"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        Background="{DynamicResource SubtleSurfaceBrush}"
                                        Visibility="{Binding ShowSpeechBubbleWarning, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="{Binding SpeechBubbleWarningText}"
                                               Style="{StaticResource BodyMutedTextStyle}"
                                               TextWrapping="Wrap" />
                                </Border>

                                <TextBlock Text="Bubble Mode" Style="{StaticResource FieldLabelTextStyle}" />
                                <ComboBox ItemsSource="{Binding SpeechBubbleModes}"
                                          SelectedItem="{Binding SpeechBubbleMode}"
                                          Style="{StaticResource AppComboBoxStyle}" />

                                <StackPanel Margin="0,12,0,0"
                                            Visibility="{Binding ShowBlankSpeechBubbleOptions, Converter={StaticResource BooleanToVisibilityConverter}}">
                                    <TextBlock Text="Bubble Size" Style="{StaticResource FieldLabelTextStyle}" />
                                    <ComboBox ItemsSource="{Binding SpeechBubbleSizes}"
                                              SelectedItem="{Binding SpeechBubbleSize}"
                                              Style="{StaticResource AppComboBoxStyle}" />
                                    <CheckBox Content="Stylized Bubble Shape"
                                              IsChecked="{Binding StylizedSpeechBubbleShape}"
                                              Margin="0,10,0,0"
                                              Style="{StaticResource AppCheckBoxStyle}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Grid>
        </Border>
        <ContentControl Content="{Binding ActiveStandardLanePanel}"
                        ContentTemplate="{StaticResource StandardLanePanelTemplate}"
                        VerticalAlignment="Top"
                        Visibility="{Binding ShowCompactTattooArtPanel, Converter={StaticResource BooleanToVisibilityConverter}}" />
        <ContentControl Content="{Binding ActiveStandardLanePanel}"
                        ContentTemplate="{StaticResource StandardLanePanelTemplate}"
                        VerticalAlignment="Top"
                        Visibility="{Binding ShowResolvedStandardLanePanel, Converter={StaticResource BooleanToVisibilityConverter}}" />
        <Border Padding="14"
                CornerRadius="18"
                BorderThickness="1"
                BorderBrush="{StaticResource HoverDeckProjectionShellBorderBrush}"
                Background="{StaticResource HoverDeckProjectionShellBackgroundBrush}"
                VerticalAlignment="Stretch"
                Visibility="{Binding ShowVintageBendModifierPanel, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Row="0"
                            Grid.Column="0">
                    <TextBlock Text="Vintage Bend Modifiers" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBlock Text="Compact semantic world-state modifiers for the Vintage Bend pack."
                               Margin="0,4,0,10"
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <UniformGrid Grid.Row="1"
                             Grid.ColumnSpan="2"
                             Columns="2">
                    <CheckBox Content="Period Artifacts"
                              IsChecked="{Binding VintageBendPeriodArtifacts}"
                              Style="{StaticResource AppCheckBoxStyle}" />
                    <CheckBox Content="Urban Civilian"
                              IsChecked="{Binding VintageBendUrbanCivilian}"
                              Style="{StaticResource AppCheckBoxStyle}" />
                </UniformGrid>
            </Grid>
        </Border>
    </StackPanel>
</UserControl>
