                            <controls:SliderFlyout Grid.Row="2" Grid.Column="1" Label="Chaos" Value="{Binding Chaos}" ValueText="{Binding ChaosValueText}" GuideText="{Binding ChaosGuideText}" HelperText="{Binding ChaosHelper}" ShowExcludeFromPrompt="True" IsExcludedFromPrompt="{Binding ExcludeChaosFromPrompt}" UseCompactChipTrigger="True" HorizontalAlignment="Right" />
                        </Grid>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Border x:Name="ArtistInfluenceCollapsedCard"
                Style="{StaticResource HoverDeckCollapsedSectionCardStyle}">
            <Button Style="{StaticResource HoverDeckCollapsedRowHeaderButtonStyle}"
                    Content="Artist Influence"
                    Tag="{Binding Visibility, ElementName=ArtistInfluenceProjectedContent}"
                    Click="OnArtistInfluenceGateClick" />
        </Border>

        <Grid Visibility="{Binding Visibility, ElementName=ArtistInfluenceProjectedContent}">
            <sharedLaneReplacements:CompactArtistInfluenceCard x:Name="ArtistInfluenceProjectedContent"
                                                               UseHostCollapseRouting="True"
                                                               CollapseRequested="OnArtistInfluenceProjectionCollapseRequested" />
        </Grid>
    </StackPanel>
</UserControl>

