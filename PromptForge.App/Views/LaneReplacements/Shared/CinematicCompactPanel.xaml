<UserControl x:Class="PromptForge.App.Views.LaneReplacements.Shared.CinematicCompactPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <UserControl.Resources>
        <Style x:Key="CinematicCompactShellStyle" TargetType="Border" BasedOn="{StaticResource SectionCardStyle}">
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="Background" Value="{DynamicResource SubtleSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource InputBorderBrush}" />
        </Style>
        <Style x:Key="CinematicCompactLabelStyle" TargetType="TextBlock" BasedOn="{StaticResource FieldLabelTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="TextTrimming" Value="None" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>

    <Border Style="{StaticResource CinematicCompactShellStyle}">
        <StackPanel>
            <TextBlock Text="{Binding Title}" Style="{StaticResource SectionTitleTextStyle}" />

            <ItemsControl ItemsSource="{Binding SubtypeSelectors}"
                          Margin="0,6,0,0"
                          Visibility="{Binding HasSubtypeSelectors, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="0,0,0,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="12" />
                                <ColumnDefinition Width="1.25*" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Label}"
                                       Style="{StaticResource CinematicCompactLabelStyle}" />
                            <ComboBox Grid.Column="2"
                                      ItemsSource="{Binding Options}"
                                      DisplayMemberPath="Label"
                                      SelectedValuePath="Key"
                                      SelectedValue="{Binding SelectedValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      Style="{StaticResource AppComboBoxStyle}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock Text="{Binding AccentSectionTitle}"
                       Style="{StaticResource FieldLabelTextStyle}"
                       Margin="0,4,0,0"
                       Visibility="{Binding HasAccentSectionTitle, Converter={StaticResource BooleanToVisibilityConverter}}" />

            <ItemsControl ItemsSource="{Binding Modifiers}"
                          Margin="0,6,0,0"
                          Visibility="{Binding HasModifiers, Converter={StaticResource BooleanToVisibilityConverter}}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Grid Width="190"
                              Margin="0,0,10,0">
                            <CheckBox Content="{Binding Label}"
                                      IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                      Style="{StaticResource AppCheckBoxStyle}" />
                        </Grid>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </Border>
</UserControl>
