<UserControl x:Class="PromptForge.App.Views.LaneReplacements.Anime.AnimeLanePanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Focusable="False">
    <StackPanel>
        <Border Padding="14"
                CornerRadius="18"
                BorderThickness="1"
                BorderBrush="{DynamicResource AccentBrush}"
                Background="{DynamicResource SubtleSurfaceBrush}"
                VerticalAlignment="Stretch"
                Visibility="{Binding ShowStandardAnimePanel, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Grid.RowSpan="2">
                    <TextBlock Text="Anime Lane"
                               Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBlock Text="Style family and era refine the anime lane without replacing the base intent."
                               Margin="0,4,0,10"
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>


                <StackPanel Grid.Row="3"
                            Grid.Column="0">
                    <TextBlock Text="Anime Style" Style="{StaticResource FieldLabelTextStyle}" />
                    <ComboBox ItemsSource="{Binding AnimeStyles}"
                              SelectedItem="{Binding AnimeStyle}"
                              Style="{StaticResource AppComboBoxStyle}" />
                    <TextBlock Text="Anime Era" Style="{StaticResource FieldLabelTextStyle}" Margin="0,10,0,0" />
                    <ComboBox ItemsSource="{Binding AnimeEras}"
                              SelectedItem="{Binding AnimeEra}"
                              Style="{StaticResource AppComboBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.Column="2">
                    <TextBlock Text="Anime Modifiers" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBlock Text="Accent injectors only. The lane keeps the strongest few and trims the rest."
                               Margin="0,4,0,10"
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <CheckBox Grid.Row="0"
                                  Grid.Column="0"
                                  Content="Cel Shading"
                                  IsChecked="{Binding AnimeCelShading}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="0"
                                  Grid.Column="2"
                                  Content="Clean Line Art"
                                  IsChecked="{Binding AnimeCleanLineArt}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="1"
                                  Grid.Column="0"
                                  Content="Expressive Eyes"
                                  IsChecked="{Binding AnimeExpressiveEyes}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="1"
                                  Grid.Column="2"
                                  Content="Dynamic Action"
                                  IsChecked="{Binding AnimeDynamicAction}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="2"
                                  Grid.Column="0"
                                  Content="Cinematic Lighting"
                                  IsChecked="{Binding AnimeCinematicLighting}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="2"
                                  Grid.Column="2"
                                  Content="Stylized Hair"
                                  IsChecked="{Binding AnimeStylizedHair}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="3"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Content="Atmospheric Effects"
                                  IsChecked="{Binding AnimeAtmosphericEffects}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="4"
                                  Grid.Column="0"
                                  Content="Character-Led Staging"
                                  IsChecked="{Binding AnimeCharacterLedStaging}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="4"
                                  Grid.Column="2"
                                  Content="Clear Silhouette Read"
                                  IsChecked="{Binding AnimeClearSilhouetteRead}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="5"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Content="Emotion-First Expression"
                                  IsChecked="{Binding AnimeEmotionFirstExpression}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                    </Grid>
                </StackPanel>

            </Grid>
        </Border>
        <Border Padding="14"
                CornerRadius="18"
                BorderThickness="1"
                BorderBrush="{DynamicResource AccentBrush}"
                Background="{DynamicResource SubtleSurfaceBrush}"
                VerticalAlignment="Stretch"
                Visibility="{Binding ShowCompactAnimePanel, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="28" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0"
                            Grid.ColumnSpan="2"
                            Grid.RowSpan="2">
                    <TextBlock Text="Anime Lane"
                               Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBlock Text="Style family and era refine the anime lane without replacing the base intent."
                               Margin="0,4,0,10"
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                </StackPanel>


                <StackPanel Grid.Row="3"
                            Grid.Column="0">
                    <TextBlock Text="Anime Style" Style="{StaticResource FieldLabelTextStyle}" />
                    <ComboBox ItemsSource="{Binding AnimeStyles}"
                              SelectedItem="{Binding AnimeStyle}"
                              Style="{StaticResource AppComboBoxStyle}" />
                    <TextBlock Text="Anime Era" Style="{StaticResource FieldLabelTextStyle}" Margin="0,10,0,0" />
                    <ComboBox ItemsSource="{Binding AnimeEras}"
                              SelectedItem="{Binding AnimeEra}"
                              Style="{StaticResource AppComboBoxStyle}" />
                </StackPanel>

                <StackPanel Grid.Row="3"
                            Grid.Column="2">
                    <TextBlock Text="Anime Modifiers" Style="{StaticResource FieldLabelTextStyle}" />
                    <TextBlock Text="Accent injectors only. The lane keeps the strongest few and trims the rest."
                               Margin="0,4,0,10"
                               Style="{StaticResource BodyMutedTextStyle}"
                               TextWrapping="Wrap" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="24" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <CheckBox Grid.Row="0"
                                  Grid.Column="0"
                                  Content="Cel Shading"
                                  IsChecked="{Binding AnimeCelShading}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="0"
                                  Grid.Column="2"
                                  Content="Clean Line Art"
                                  IsChecked="{Binding AnimeCleanLineArt}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="1"
                                  Grid.Column="0"
                                  Content="Expressive Eyes"
                                  IsChecked="{Binding AnimeExpressiveEyes}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="1"
                                  Grid.Column="2"
                                  Content="Dynamic Action"
                                  IsChecked="{Binding AnimeDynamicAction}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="2"
                                  Grid.Column="0"
                                  Content="Cinematic Lighting"
                                  IsChecked="{Binding AnimeCinematicLighting}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="2"
                                  Grid.Column="2"
                                  Content="Stylized Hair"
                                  IsChecked="{Binding AnimeStylizedHair}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="3"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Content="Atmospheric Effects"
                                  IsChecked="{Binding AnimeAtmosphericEffects}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="4"
                                  Grid.Column="0"
                                  Content="Character-Led Staging"
                                  IsChecked="{Binding AnimeCharacterLedStaging}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="4"
                                  Grid.Column="2"
                                  Content="Clear Silhouette Read"
                                  IsChecked="{Binding AnimeClearSilhouetteRead}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                        <CheckBox Grid.Row="5"
                                  Grid.Column="0"
                                  Grid.ColumnSpan="3"
                                  Content="Emotion-First Expression"
                                  IsChecked="{Binding AnimeEmotionFirstExpression}"
                                  Style="{StaticResource AppCheckBoxStyle}" />
                    </Grid>
                </StackPanel>

            </Grid>
        </Border>
    </StackPanel>
</UserControl>
