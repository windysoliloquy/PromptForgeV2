<Window x:Class="PromptForge.App.UnlockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompt Forge Version Info"
        Icon="/Assets/PromptForge.ico"
        Width="950"
        Height="780"
        MinWidth="950"
        MinHeight="780"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}">
    <Border Style="{StaticResource CardBorderStyle}" Margin="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="StatusHeadlineTextBlock"
                           Text="Prompt Forge Version Info"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock x:Name="StatusBodyTextBlock"
                           Text="Demo mode is active."
                           Style="{StaticResource BodyMutedTextStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <ScrollViewer Grid.Row="1"
                          Margin="0,16,0,16"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource BodyMutedTextStyle}" TextWrapping="Wrap">
                        <Hyperlink Click="OnCommunityLinkClick">COME JOIN US AND SHARE YOUR CREATIONS AT THIS LINK!!</Hyperlink>
                    </TextBlock>
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Purchase Options" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBox Margin="0,8,0,0"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Disabled"
                                 MinHeight="560"
                                 Text="Direct purchase is available by email. Accepted payment methods are PayPal, Cash App, and credit/debit card. Unlock files are delivered directly after payment.&#x0a;&#x0a;Base access includes 5 free lanes&#x0a;&#x0a;&#8226; Photography&#x0a;&#8226; Cinematic&#x0a;&#8226; Watercolor&#x0a;&#8226; Pixel Art&#x0a;&#8226; Graphic Design&#x0a;&#x0a;Prompt Forge App Unlock — $19.99&#x0a;&#x0a;One-time purchase. Includes app unlock, 1 locked premium lane of your choice, 1 week of complimentary group session access, and very limited email help and tips for one particular image project.&#x0a;&#x0a;Purchasers may also submit feature suggestions, and purchaser suggestions receive higher-priority consideration.&#x0a;&#x0a;Group session plans&#x0a;&#x0a;Monthly — $6.99&#x0a;Group session access for 1 month. Also includes 1 permanent locked premium lane unlock for your app.&#x0a;&#x0a;Quarterly — $17.99&#x0a;Group session access for 3 months. Also includes 5 permanent locked premium lane unlocks for your app.&#x0a;&#x0a;Yearly — $49.99&#x0a;Group session access for 1 year. Also includes all locked premium lanes permanently unlocked for your app.&#x0a;&#x0a;Lane unlocks included with these purchases are permanent. Group session access is time-based, but app lane unlocks do not expire. Buyers do not have to attend group sessions if they only want the included lane unlocks.&#x0a;&#x0a;Additional premium lane unlocks&#x0a;&#x0a;Additional premium lane options may also be purchased separately. Contact by email for current lane-pack pricing.&#x0a;&#x0a;Commercial pricing&#x0a;&#x0a;Commercial pricing is handled separately through direct email.&#x0a;&#x0a;Aggressive, disruptive, or abusive behavior toward other users can result in removal from group access without a refund.&#x0a;&#x0a;Contact:&#x0a;WindySoliloquy@gmail.com" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Offline unlock file requirements:" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Text="After purchase, your unlock file will be sent to you directly. Once you receive it, use the Import button below to select it. Because delivery is handled manually, file delivery and any included support or group access may not be immediate. Please keep your time zone and time of day in mind when ordering. I will do my best to get everything sent and set up the same day."
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Activation Request Code"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Margin="0,12,0,0" />
                        <TextBox x:Name="ActivationRequestCodeTextBox"
                                 Margin="0,8,0,0"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled" />
                            <TextBlock Text="Use this code when you want a machine-bound unlock for this specific computer."
                                       Style="{StaticResource BodyMutedTextStyle}"
                                       Margin="0,8,0,0"
                                       TextWrapping="Wrap" />
                        <TextBlock x:Name="LicenseSummaryTextBlock"
                                   Text="No license imported yet."
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
                </StackPanel>
            </ScrollViewer>

            <UniformGrid Grid.Row="2" Columns="3">
                <Button Content="Email to Purchase"
                        Click="OnEmailToPurchaseClick"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="Import Unlock File"
                        Click="OnImportUnlockFileClick"
                        Style="{StaticResource EmphasisSecondaryButtonStyle}" />
                <Button Content="Close"
                        Click="OnCloseClick"
                        Style="{StaticResource TertiaryButtonStyle}" />
            </UniformGrid>
        </Grid>
    </Border>
</Window>
