<Window x:Class="PromptForge.App.UnlockWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompt Forge Version Info"
        Width="950"
        Height="780"
        MinWidth="950"
        MinHeight="780"
        WindowStartupLocation="CenterOwner"
        WindowState="Maximized"
        ResizeMode="NoResize"
        Background="{DynamicResource AppBackgroundBrush}">
    <Border Style="{StaticResource CardBorderStyle}" Margin="16" Padding="20">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock x:Name="StatusHeadlineTextBlock"
                           Text="Prompt Forge Version Info"
                           Style="{StaticResource SectionTitleTextStyle}" />
                <TextBlock x:Name="StatusBodyTextBlock"
                           Text="Demo mode is active."
                           Style="{StaticResource BodyMutedTextStyle}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="1" Margin="0,16,0,16">
                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,12">
                    <TextBlock Style="{StaticResource BodyMutedTextStyle}" TextWrapping="Wrap">
                        <Hyperlink Click="OnCommunityLinkClick">COME JOIN US AND SHARE YOUR CREATIONS AT THIS LINK!!</Hyperlink>
                    </TextBlock>
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Purchase Options" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBox Margin="0,8,0,0"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled"
                                 Height="352"
                                 Text="Direct purchase is available by email. Accepted payment methods are PayPal, Cash App, or credit/debit card. The unlock file is delivered directly after payment.&#x0a;&#x0a;Prompt Forge Full is $19.99 and includes very limited email support and tips for one particular image project.&#x0a;&#x0a;Purchasers may also submit feature suggestions, and purchaser suggestions receive higher-priority consideration.&#x0a;&#x0a;The $49.99 Premium tier is for ChatGPT Plus or Pro web users and includes one year of group chat sessions with top image prompters, AI enthusiasts, and developers. Sessions are not limited to image help and are not focused on a single art project.&#x0a;&#x0a;Topics may vary broadly across ChatGPT use. When helpful, participants may be offered the option to join a different group where interests better align. They may also choose to remain in their current group.&#x0a;&#x0a;For easier access, the email used to contact me should match the purchaser's ChatGPT Plus or Pro account email if they want to be added to the Premium group experience.&#x0a;&#x0a;Aggressive behavior toward other users will result in removal from group access without a refund.&#x0a;&#x0a;Contact: WindySoliloquy@gmail.com" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource InfoChipBorderStyle}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Offline unlock file requirements:" Style="{StaticResource FieldLabelTextStyle}" />
                        <TextBlock Text="After purchase, your unlock file will be sent to you directly. Once you receive it, use the Import button below to select it. Because delivery is handled manually, file delivery and any included support or group access may not be immediate. Please keep your time zone and time of day in mind when ordering. I will do my best to get everything sent and set up the same day."
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="Activation Request Code"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Margin="0,12,0,0" />
                        <TextBox x:Name="ActivationRequestCodeTextBox"
                                 Margin="0,8,0,0"
                                 Style="{StaticResource AppTextBoxStyle}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Disabled"
                                 HorizontalScrollBarVisibility="Disabled" />
                        <TextBlock Text="Use this code when you want a machine-bound unlock for this specific computer. Trusted-user portable licenses can still be issued without it."
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap" />
                        <TextBlock x:Name="LicenseSummaryTextBlock"
                                   Text="No license imported yet."
                                   Style="{StaticResource BodyMutedTextStyle}"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </StackPanel>

            <UniformGrid Grid.Row="2" Columns="3">
                <Button Content="Email to Purchase"
                        Click="OnEmailToPurchaseClick"
                        Style="{StaticResource PrimaryButtonStyle}" />
                <Button Content="Import Unlock File"
                        Click="OnImportUnlockFileClick"
                        Style="{StaticResource EmphasisSecondaryButtonStyle}" />
                <Button Content="Close"
                        Click="OnCloseClick"
                        Style="{StaticResource TertiaryButtonStyle}" />
            </UniformGrid>
        </Grid>
    </Border>
</Window>
